<UserControl x:Class="LSS_prototype.ImageComment_Page.ImageComment"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Height="1080" Width="1920"
        Background="#173753"
        d:DesignWidth="1920" d:DesignHeight="1080">

    <UserControl.Resources>
        <SolidColorBrush x:Key="Panel"      Color="#1C2B3A"/>
        <SolidColorBrush x:Key="Card"       Color="#243447"/>
        <SolidColorBrush x:Key="CardBorder" Color="#2E4460"/>
        <SolidColorBrush x:Key="ValueBg"    Color="#1A2D3E"/>
        <SolidColorBrush x:Key="BtnDark"    Color="#2A3F55"/>
        <SolidColorBrush x:Key="Inactive"   Color="#94A3B8"/>
        <SolidColorBrush x:Key="Accent"     Color="#3B82F6"/>

        <Style x:Key="BaseBtn" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background" Value="{StaticResource BtnDark}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize"   Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="AccentBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize"   Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background" Value="#7F1D1D"/>
            <Setter Property="Foreground" Value="#FCA5A5"/>
            <Setter Property="FontSize"   Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="ExitBtn" TargetType="Button">
            <Setter Property="Background"      Value="#111827"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontSize"        Value="20"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="72"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background" Value="{StaticResource BtnDark}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="ColorBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background" Value="{StaticResource BtnDark}"/>
            <Setter Property="Height"     Value="52"/>
        </Style>

        <Style x:Key="TouchSlider" TargetType="Slider">
            <Setter Property="Minimum"           Value="2"/>
            <Setter Property="Maximum"           Value="20"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Height="44" Background="Transparent">
                                <Grid VerticalAlignment="Center">
                                    <Border Height="8" CornerRadius="4"
                                            Background="{StaticResource BtnDark}"
                                            Margin="22,0"/>
                                    <Track x:Name="PART_Track" Margin="0">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Command="Slider.DecreaseLarge" Focusable="False">
                                                <RepeatButton.Template>
                                                    <ControlTemplate TargetType="RepeatButton">
                                                        <Border Height="8" CornerRadius="4,0,0,4"
                                                                Background="{StaticResource Accent}"
                                                                VerticalAlignment="Center"/>
                                                    </ControlTemplate>
                                                </RepeatButton.Template>
                                            </RepeatButton>
                                        </Track.DecreaseRepeatButton>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Command="Slider.IncreaseLarge" Focusable="False">
                                                <RepeatButton.Template>
                                                    <ControlTemplate TargetType="RepeatButton">
                                                        <Border Background="Transparent"/>
                                                    </ControlTemplate>
                                                </RepeatButton.Template>
                                            </RepeatButton>
                                        </Track.IncreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb>
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Grid Width="44" Height="44">
                                                            <Ellipse Fill="#40000000" Margin="-2"/>
                                                            <Ellipse Fill="White"/>
                                                            <Ellipse Width="14" Height="14"
                                                                     Fill="{StaticResource Accent}"
                                                                     HorizontalAlignment="Center"
                                                                     VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Background"      Value="{StaticResource Card}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderBrush"     Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="17"/>
            <Setter Property="Height"          Value="52"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0"
                                    Content="{TemplateBinding SelectionBoxItem}"
                                    Margin="14,0,0,0" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="▾"
                                           Foreground="{StaticResource Inactive}"
                                           FontSize="14" VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                                <Popup x:Name="PART_Popup"
                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                       Placement="Bottom" AllowsTransparency="True">
                                    <Border Background="{StaticResource Card}"
                                            BorderBrush="{StaticResource CardBorder}"
                                            BorderThickness="1" CornerRadius="10"
                                            MinWidth="{TemplateBinding ActualWidth}">
                                        <ScrollViewer MaxHeight="220">
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground"  Value="White"/>
                        <Setter Property="Background"  Value="{StaticResource Card}"/>
                        <Setter Property="Padding"     Value="14,10"/>
                        <Setter Property="FontSize"    Value="16"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="{StaticResource BtnDark}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource Panel}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="440"/>
        </Grid.ColumnDefinitions>

        <!-- ══ 좌측: 이미지 ══ -->
        <Border Grid.Column="0" Background="Black"
                Margin="10,10,5,10" CornerRadius="8" ClipToBounds="True">
            <Grid>
                <Image x:Name="CapturedImage" Stretch="Uniform"/>
                <InkCanvas x:Name="DrawingCanvas" Background="Transparent"/>

                <!-- 좌상단: 환자 정보 -->
                <StackPanel Margin="16,12" VerticalAlignment="Top" HorizontalAlignment="Left">
                    <TextBlock Foreground="White" FontSize="18" FontWeight="Bold">
                        <Run Text="{Binding SelectedPatient.DisplayName, Mode=OneWay}"/>
                        <Run Text="("/>
                        <Run Text="{Binding SelectedPatient.PatientCode}"/>
                        <Run Text=")"/>
                    </TextBlock>
                    <TextBlock Foreground="White" FontSize="16">
                        <Run Text="{Binding SelectedPatient.BirthDate, StringFormat=yyyy-MM-dd}"/>
                        <Run Text=" / "/>
                        <Run Text="{Binding SelectedPatient.Sex}"/>
                    </TextBlock>
                </StackPanel>

                <TextBlock Text="{Binding PageIndicator}" Foreground="White"
                           FontSize="18" FontWeight="Bold"
                           HorizontalAlignment="Right" VerticalAlignment="Top"
                           Margin="0,12,16,0"/>
            </Grid>
        </Border>

        <!-- ══ 우측 패널 ══ -->
        <Grid Grid.Column="1" Margin="5,10,10,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="90"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource Card}" CornerRadius="12">
                <Grid Margin="16,18,16,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- R0:  Position 라벨 -->
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="52"/>
                        <!-- R2:  Position 콤보 -->
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <!-- R4:  Anatomical 라벨 -->
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="52"/>
                        <!-- R6:  Anatomical 콤보 -->
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <!-- R8:  Comment 라벨 -->
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="240"/>
                        <!-- R10: Comment 입력 (높이 고정) -->
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="66"/>
                        <!-- R12: IMAGE DELETE -->
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="66"/>
                        <!-- R14: RESET -->
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="66"/>
                        <!-- R16: SAVE -->
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="1"/>
                        <!-- R18: 구분선 -->
                        <RowDefinition Height="12"/>

                        <!-- ── 팔레트 영역 ── -->
                        <RowDefinition Height="52"/>
                        <!-- R20: PEN / ERASE / CLEAR -->
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="52"/>
                        <!-- R22: 색상 버튼 -->
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="52"/>
                        <!-- R24: 굵기 슬라이더 -->
                    </Grid.RowDefinitions>

                    <!-- Position -->
                    <TextBlock Grid.Row="0" Text="Position"
                               Foreground="White" FontSize="18" FontWeight="Bold"/>
                    <ComboBox Grid.Row="2" x:Name="CbPosition" Style="{StaticResource DarkCombo}">
                        <ComboBoxItem>Left</ComboBoxItem>
                        <ComboBoxItem>Right</ComboBoxItem>
                        <ComboBoxItem>Top</ComboBoxItem>
                        <ComboBoxItem>Bottom</ComboBoxItem>
                    </ComboBox>

                    <!-- Anatomical -->
                    <TextBlock Grid.Row="4" Text="Anatomical Directional"
                               Foreground="White" FontSize="18" FontWeight="Bold"/>
                    <ComboBox Grid.Row="6" x:Name="CbAnatomical" Style="{StaticResource DarkCombo}">
                        <ComboBoxItem>Anterior</ComboBoxItem>
                        <ComboBoxItem>Posterior</ComboBoxItem>
                        <ComboBoxItem>Lateral</ComboBoxItem>
                        <ComboBoxItem>Medial</ComboBoxItem>
                    </ComboBox>

                    <!-- Comment -->
                    <TextBlock Grid.Row="8" Text="Comment"
                               Foreground="White" FontSize="18" FontWeight="Bold"/>
                    <Border Grid.Row="10" Background="{StaticResource ValueBg}"
                            BorderBrush="{StaticResource CardBorder}"
                            BorderThickness="1" CornerRadius="10">
                        <TextBox x:Name="TxtComment"
                                 Text="{Binding CommentText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="White" FontSize="15"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Padding="12,10" CaretBrush="White"/>
                    </Border>

                    <!-- IMAGE DELETE -->
                    <Button Grid.Row="12" x:Name="BtnImageDelete"
                            Content="IMAGE DELETE"
                            Style="{StaticResource DangerBtn}"
                            Command="{Binding ImageDeleteCommand}"/>

                    <!-- RESET -->
                    <Button Grid.Row="14" x:Name="BtnReset"
                            Content="RESET" Style="{StaticResource DarkBtn}"
                            Click="BtnReset_Click"/>

                    <!-- SAVE -->
                    <Button Grid.Row="16" x:Name="BtnSave"
                            Content="SAVE" Style="{StaticResource AccentBtn}"
                            Command="{Binding SaveCommand}"/>

                    <!-- 구분선 -->
                    <Border Grid.Row="18" Background="{StaticResource CardBorder}"/>

                    <!-- ── R20: 툴 버튼 (PEN / ERASE / CLEAR) ── -->
                    <Grid Grid.Row="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" x:Name="BtnPen"
                                Style="{StaticResource ToolBtn}"
                                Background="{StaticResource BtnDark}"
                                Click="BtnPen_Click">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="✏" FontSize="18" HorizontalAlignment="Center"/>
                                <TextBlock Text="PEN" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="2" x:Name="BtnErase"
                                Style="{StaticResource ToolBtn}"
                                Click="BtnErase_Click">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="⌫" FontSize="18" HorizontalAlignment="Center"/>
                                <TextBlock Text="ERASE" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="4" x:Name="BtnClear"
                                Style="{StaticResource ToolBtn}"
                                Click="BtnClear_Click">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="🗑" FontSize="16" HorizontalAlignment="Center"/>
                                <TextBlock Text="CLEAR" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- ── R22: 색상 버튼 ── -->
                    <Grid Grid.Row="22">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Style="{StaticResource ColorBtn}"
                                Tag="#FF4444" Click="ColorBtn_Click" ToolTip="빨강">
                            <Ellipse Width="28" Height="28" Fill="#FF4444"/>
                        </Button>
                        <Button Grid.Column="2" Style="{StaticResource ColorBtn}"
                                Tag="#FFD700" Click="ColorBtn_Click" ToolTip="노랑">
                            <Ellipse Width="28" Height="28" Fill="#FFD700"/>
                        </Button>
                        <Button Grid.Column="4" Style="{StaticResource ColorBtn}"
                                Tag="#00E676" Click="ColorBtn_Click" ToolTip="초록">
                            <Ellipse Width="28" Height="28" Fill="#00E676"/>
                        </Button>
                        <Button Grid.Column="6" Style="{StaticResource ColorBtn}"
                                Tag="#FFFFFF" Click="ColorBtn_Click" ToolTip="흰색">
                            <Ellipse Width="28" Height="28" Fill="#FFFFFF"/>
                        </Button>
                    </Grid>

                    <!-- ── R24: 굵기 슬라이더 ── -->
                    <Grid Grid.Row="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="44"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="굵기" Foreground="{StaticResource Inactive}"
                                   FontSize="13" VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>

                        <Slider Grid.Column="1" x:Name="SliderThickness"
                                Style="{StaticResource TouchSlider}"
                                Minimum="2" Maximum="20" Value="4"
                                ValueChanged="SliderThickness_ValueChanged"/>

                        <Border Grid.Column="3" Background="{StaticResource ValueBg}"
                                CornerRadius="8" Width="44" Height="44">
                            <TextBlock x:Name="TxtThickness"
                                       Text="4" Foreground="White"
                                       FontSize="16" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>

                </Grid>
            </Border>

            <!-- BACK + EXIT -->
            <Grid Grid.Row="2" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Style="{StaticResource ExitBtn}"
                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                        Margin="0,0,4,0" Click="Back_Click">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="⬅︎" FontSize="40" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="1" Content="EXIT"
                        Style="{StaticResource ExitBtn}"
                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                        Margin="4,0,0,0" Command="{Binding ExitCommand}"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>

<UserControl x:Class="LSS_prototype.ImageReview_Page.ImageReview"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1920" d:DesignHeight="1080"
        FontFamily="Arial"
        Background="#0F1B28">

    <UserControl.Resources>
        <!-- 오버레이 네비 슬라이드 -->
        <Storyboard x:Key="NavIn">
            <DoubleAnimation Storyboard.TargetName="NavBar"
                Storyboard.TargetProperty="Height"
                From="0" To="100"
                Duration="0:0:0.01"/>

            <DoubleAnimation Storyboard.TargetName="NavTT"
                     Storyboard.TargetProperty="X"
                     From="1200" To="0"
                     Duration="0:0:0.28">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="NavOut">
            <DoubleAnimation Storyboard.TargetName="NavTT"
                     Storyboard.TargetProperty="X"
                     From="0" To="1200"
                     Duration="0:0:0.22">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <DoubleAnimation Storyboard.TargetName="NavBar"
                Storyboard.TargetProperty="Height"
                From="100" To="0"
                Duration="0:0:0.01"
                BeginTime="0:0:0.21"/>
        </Storyboard>

        <SolidColorBrush x:Key="PanelBrush" Color="#1C2B3A"/>
        <SolidColorBrush x:Key="PanelDarkBrush" Color="#1A2634"/>
        <SolidColorBrush x:Key="ButtonBrush" Color="#253849"/>
        <SolidColorBrush x:Key="BorderBrushColor" Color="#31495F"/>

        <Style x:Key="BaseBtn" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionBtnStyle" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background" Value="#2A4157"/>
            <Setter Property="BorderBrush" Value="#415D77"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="58"/>
        </Style>

        <Style x:Key="IconBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background" Value="#2A3F55"/>
            <Setter Property="Width" Value="56"/>
            <Setter Property="Height" Value="56"/>
            <Setter Property="FontSize" Value="34"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="ExitBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="56"/>
        </Style>

        <Style x:Key="NavBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background" Value="#F3F5F7"/>
            <Setter Property="Foreground" Value="#17324D"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Width" Value="210"/>
            <Setter Property="Height" Value="70"/>
        </Style>

        <Style x:Key="NavBtnActive" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background" Value="#4C87F0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Width" Value="210"/>
            <Setter Property="Height" Value="70"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="#0F1B28">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="390"/>
        </Grid.ColumnDefinitions>

        <!-- 좌측 메인 -->
        <Grid Grid.Column="0" Background="Black">
            <Image Source="{Binding SelectedImage}"
                   Stretch="Uniform"/>

            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <TextBlock Text="촬영된 사진이"
                           Foreground="White"
                           FontSize="34"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="보여질 공간입니다."
                           Foreground="White"
                           FontSize="34"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- 좌상단: 환자 정보 -->
            <StackPanel Margin="16,12" VerticalAlignment="Top" HorizontalAlignment="Left">
                <TextBlock Foreground="White" FontSize="18" FontWeight="Bold">
         <Run Text="{Binding SelectedPatient.DisplayName, Mode=OneWay}"/>
         <Run Text="("/>
         <Run Text="{Binding SelectedPatient.PatientCode}"/>
         <Run Text=")"/>
                </TextBlock>

                <TextBlock Foreground="White" FontSize="16">
         <Run Text="{Binding SelectedPatient.BirthDate, StringFormat=yyyy-MM-dd}"/>
         <Run Text=" / "/>
         <Run Text="{Binding SelectedPatient.Sex}"/>
                </TextBlock>
            </StackPanel>


            <TextBlock Text="1 / 12"
                       Margin="0,10,14,0"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="Bold"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Top"/>

            <TextBlock Text="촬영일자 : 2026-03-23 14:23:54"
                       Margin="14,0,0,10"
                       Foreground="White"
                       FontSize="18"
                       FontWeight="Bold"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Bottom"/>
        </Grid>

        <!-- 하단 Nav Bar -->
        <Grid x:Name="NavBar"
      VerticalAlignment="Bottom"
      Height="0"
      ClipToBounds="True">
            <Border Background="#E61C2B3A"/>
            <Grid>
                <Grid.RenderTransform>
                    <TranslateTransform x:Name="NavTT" X="1200"/>
                </Grid.RenderTransform>

                <StackPanel Orientation="Horizontal"
                    Margin="16,0"
                    VerticalAlignment="Center">
                    <Button Content="Patient"
                    Style="{StaticResource NavBtn}"
                    Command="{Binding NavigatePatientCommand}"
                    Margin="0,0,10,0"/>

                    <Button Content="Scan"
                    Style="{StaticResource NavBtn}"
                    Command="{Binding NavigateScanCommand}"
                    Margin="0,0,10,0"/>

                    <Button Content="Image Review"
                    Style="{StaticResource NavBtnActive}"
                    Margin="0,0,10,0"/>

                    <Button Content="Video Review"
                    Style="{StaticResource NavBtn}"
                    Command="{Binding NavigateVideoReviewCommand}"/>
                </StackPanel>
            </Grid>
        </Grid>
        <!-- 우측 패널 -->
        <Grid Grid.Column="1">
            <Border Background="{StaticResource PanelBrush}"
                    BorderBrush="#24394D"
                    BorderThickness="1,0,0,0">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="150"/>
                        <RowDefinition Height="200"/>
                        <RowDefinition Height="82"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="100"/>
                    </Grid.RowDefinitions>

                    <!-- 상단 4개 버튼 -->
                    <Border Grid.Row="0"
                            Background="{StaticResource PanelDarkBrush}"
                            BorderBrush="{StaticResource BorderBrushColor}"
                            BorderThickness="0,0,0,1"
                            Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Button Grid.Row="0" Grid.Column="0"
                                    Content="Delete"
                                    Margin="0,0,6,6"
                                    Style="{StaticResource ActionBtnStyle}"/>

                            <Button Grid.Row="0" Grid.Column="1"
                                    Content="Edit"
                                    Margin="6,0,0,6"
                                    Style="{StaticResource ActionBtnStyle}"/>

                            <Button Grid.Row="1" Grid.Column="0"
                                    Content="Export"
                                    Margin="0,6,6,0"
                                    Style="{StaticResource ActionBtnStyle}"/>

                            <Button Grid.Row="1" Grid.Column="1"
                                    Content="Pacs"
                                    Margin="6,6,0,0"
                                    Style="{StaticResource ActionBtnStyle}"/>
                        </Grid>
                    </Border>

                    <!-- Comment -->
                    <Border Grid.Row="1"
                            Background="{StaticResource PanelDarkBrush}"
                            BorderBrush="{StaticResource BorderBrushColor}"
                            BorderThickness="0,0,0,1"
                            Padding="12">
                        <Border Background="#13202E"
                                BorderBrush="{StaticResource BorderBrushColor}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="16"
                                Height="166"
                                VerticalAlignment="Center">
                            <TextBlock Text="코멘트창에서 남겨진 리뷰가 보여집니다."
                                       Foreground="#D6E3F3"
                                       FontSize="16"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Border>

                    <!-- 날짜 필터 -->
                    <Border Grid.Row="2"
                        Background="{StaticResource PanelDarkBrush}"
                        BorderBrush="{StaticResource BorderBrushColor}"
                        BorderThickness="0,0,0,1"
                        Padding="12">
                        <Button Content="날짜순 ▼"
                            Style="{StaticResource BaseBtn}"
                            Background="{StaticResource ButtonBrush}"
                            BorderBrush="{StaticResource BorderBrushColor}"
                            BorderThickness="1"
                            FontSize="16"
                            FontWeight="Bold"
                            Height="48"/>
                    </Border>

                    <!-- 날짜별 썸네일 리스트 -->
                    <ScrollViewer Grid.Row="3"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled"
                        Background="{StaticResource PanelBrush}">
                        <StackPanel Margin="12,12,12,8">

                            <ItemsControl ItemsSource="{Binding AvailableDates}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,12">

                                            <!-- 날짜 헤더 -->
                                            <Border Background="#182634"
                                                BorderBrush="{StaticResource BorderBrushColor}"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                Padding="16"
                                                Height="60">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Text="{Binding DisplayDate}"
                                                        Foreground="#F4F8FF"
                                                        FontSize="18"
                                                        FontWeight="Bold"
                                                        VerticalAlignment="Center"/>

                                                    <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding ImageCountText}"
                                                            Foreground="#9DB0C4"
                                                            FontSize="14"
                                                            Margin="0,0,8,0"/>

                                                        <ToggleButton IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                                            Width="28"
                                                            Height="28"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Cursor="Hand">
                                                            <TextBlock Text="▼"
                                                                Foreground="White"
                                                                FontWeight="Bold"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"/>
                                                            <ToggleButton.Style>
                                                                <Style TargetType="ToggleButton">
                                                                    <Setter Property="Template">
                                                                        <Setter.Value>
                                                                            <ControlTemplate TargetType="ToggleButton">
                                                                                <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Style>
                                                            </ToggleButton.Style>
                                                        </ToggleButton>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>

                                            <!-- 펼쳐졌을 때만 썸네일 -->
                                            <ItemsControl ItemsSource="{Binding Images}">
                                                <ItemsControl.Style>
                                                    <Style TargetType="ItemsControl">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ItemsControl.Style>

                                                <ItemsControl.Margin>
                                                    <Thickness>0,10,0,0</Thickness>
                                                </ItemsControl.Margin>

                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="#223445"
                                                            BorderBrush="#4F8DFF"
                                                            BorderThickness="1.5"
                                                            CornerRadius="16"
                                                            Padding="8"
                                                            Margin="0,0,0,12">
                                                            <StackPanel>
                                                                <Border Height="170"
                                                                Background="#1D3555"
                                                                CornerRadius="12"
                                                                BorderBrush="#33FFFFFF"
                                                                BorderThickness="1"
                                                                ClipToBounds="True">
                                                                    <Grid Background="#1D3555">
                                                                        <Image Source="{Binding Thumbnail}"
                                                                            Stretch="UniformToFill"
                                                                            HorizontalAlignment="Stretch"
                                                                            VerticalAlignment="Center"/>
                                                                    </Grid>
                                                                </Border>

                                                                <TextBlock Text="{Binding Date, StringFormat=촬영일자 : {0}}"
                                                                    Foreground="#E7EEF9"
                                                                    FontSize="15"
                                                                    FontWeight="Bold"
                                                                    Margin="0,8,0,0"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </ScrollViewer>


                    <!-- 우측 패널 하단 -->
                    <Grid Grid.Row="4" Background="{StaticResource PanelBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="210"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0"
                            VerticalAlignment="Center"
                            Margin="8,0,0,0">

                            <Button x:Name="ToggleBtn"
                                Style="{StaticResource IconBtn}"
                                Width="72"
                                Height="72"
                                Click="ToggleNav_Click">

                                <TextBlock Text="❯"
                                FontSize="28"
                                FontWeight="Bold"
                                Foreground="White"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
                            </Button>
                        </Grid>

                        <Grid Grid.Column="1"/>

                        <Grid Grid.Column="2" Margin="0,0,8,0">
                            <Grid.ColumnDefinitions>
                                 <ColumnDefinition Width="80"/>   <!-- 기존 58 -->
                                 <ColumnDefinition Width="120"/>  <!-- 기존 90 -->
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Style="{StaticResource ExitBtn}"
                                    Width="72"
                                    Height="72"
                                    Margin="0,10,8,10">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="⏻"
                                        FontSize="22"
                                        HorizontalAlignment="Center"/>
                                    <TextBlock Text="LOGOUT"
                                        FontSize="12"
                                        HorizontalAlignment="Center"
                                        Margin="0,4,0,0"/>
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="1"
                                Content="EXIT"
                                Style="{StaticResource ExitBtn}"
                                Width="110"
                                Height="72"
                                Margin="8,10,0,10"/>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
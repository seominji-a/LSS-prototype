<Window x:Class="LSS_prototype.Login_Page.SessionLogin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LSS_prototype.Login_Page"
        mc:Ignorable="d"
        Title="SessionLogin"
        Width="960"
        Height="720"
        ResizeMode="NoResize"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.DataContext>
        <local:SessionLoginViewModel />
    </Window.DataContext>

    <Window.Resources>
        <!-- ── 색상 ── -->
        <SolidColorBrush x:Key="Bg"           Color="#F3F5F7"/>
        <SolidColorBrush x:Key="Primary"       Color="#173753"/>
        <SolidColorBrush x:Key="PrimaryHover"  Color="#1F4767"/>
        <SolidColorBrush x:Key="PrimaryDown"   Color="#102A3F"/>
        <SolidColorBrush x:Key="TextDark"      Color="#1E293B"/>
        <SolidColorBrush x:Key="TextMuted"     Color="#64748B"/>
        <SolidColorBrush x:Key="InputBg"       Color="#FFFFFF"/>
        <SolidColorBrush x:Key="InputBorder"   Color="#D6DEE8"/>

        <!-- ── 입력 박스 Border ── -->
        <Style x:Key="InputBoxBorderStyle" TargetType="Border">
            <Setter Property="Background"       Value="{StaticResource InputBg}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource InputBorder}"/>
            <Setter Property="BorderThickness"  Value="2"/>
            <Setter Property="CornerRadius"     Value="12"/>
            <Setter Property="Height"           Value="64"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <!-- ── Primary 버튼 (UNLOCK) ── -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background"       Value="{StaticResource Primary}"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="FontSize"         Value="24"/>
            <Setter Property="FontFamily"       Value="Arial"/>
            <Setter Property="FontWeight"       Value="SemiBold"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Height"           Value="64"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Padding="18,10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryHover}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryDown}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Footer 버튼 (LOGOUT / EXIT) ── Login.xaml의 EXIT 버튼과 동일 스타일 -->
        <Style x:Key="FooterButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#94A3B8"/>
            <Setter Property="FontSize"        Value="30"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="FontFamily"      Value="Arial"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#EF4444"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource Bg}"
            CornerRadius="16"
            SnapsToDevicePixels="True">
        <Grid>

            <!-- ════ 좌측 하단: LOGOUT 버튼 ════ -->
            <Button Content="LOGOUT"
                    Width="130" Height="36"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Margin="24,0,0,20"
                    Style="{StaticResource FooterButtonStyle}"
                    Command="{Binding LogoutCommand}"/>

            <!-- ════ 우측 하단: EXIT 버튼 ════ -->
            <Button Content="EXIT"
                    Width="90" Height="36"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,20,20"
                    Style="{StaticResource FooterButtonStyle}"
                    Command="{Binding ExitCommand}"/>

            <!-- ════ 가운데 콘텐츠 ════ -->
            <Grid HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Width="480"
                  Margin="0,0,0,60">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- 0: 타이틀 블록 -->
                    <RowDefinition Height="28"/>    <!-- 1: Gap -->
                    <RowDefinition Height="Auto"/>  <!-- 2: 안내 메시지 -->
                    <RowDefinition Height="16"/>    <!-- 3: Gap -->
                    <RowDefinition Height="Auto"/>  <!-- 4: CapsLock 경고 -->
                    <RowDefinition Height="6"/>     <!-- 5: Gap -->
                    <RowDefinition Height="Auto"/>  <!-- 6: PasswordBox -->
                    <RowDefinition Height="22"/>    <!-- 7: Gap -->
                    <RowDefinition Height="Auto"/>  <!-- 8: UNLOCK 버튼 -->
                </Grid.RowDefinitions>

                <!-- ── 타이틀 블록 ── -->
                <StackPanel Grid.Row="0" HorizontalAlignment="Center">
                    <TextBlock Text="LOCKED"
                               FontSize="72" FontWeight="Bold" FontFamily="Arial"
                               Foreground="{StaticResource Primary}"
                               HorizontalAlignment="Center"/>
                    <Border Height="4" Width="140"
                            Background="{StaticResource Primary}"
                            CornerRadius="2"
                            HorizontalAlignment="Center"
                            Margin="0,18,0,0"/>
                    <TextBlock Text="(주)에스원바이오 LSS"
                               FontSize="18" FontFamily="Arial"
                               Foreground="#94A3B8"
                               HorizontalAlignment="Center"
                               Margin="0,14,0,0"/>
                </StackPanel>

                <!-- ── 안내 메시지 ── -->
                <StackPanel Grid.Row="2" HorizontalAlignment="Center">
                    <TextBlock Text="세션이 잠겼습니다."
                               FontSize="20" FontWeight="Bold"
                               Foreground="#EF4444"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>
                    <TextBlock FontSize="16" FontFamily="Arial"
                               Foreground="{StaticResource TextMuted}"
                               HorizontalAlignment="Center">
                        <Run Text="{Binding CurrentUserName, Mode=OneWay}"/><Run Text="님, 비밀번호를 입력해주세요."/>
                    </TextBlock>
                </StackPanel>

                <!-- ── 캡스락 경고 ── -->
                <TextBlock x:Name="CapsLockWarning"
                           Grid.Row="4"
                           Text="Caps Lock is ON. Password is case-sensitive."
                           FontFamily="Arial" FontSize="17" FontWeight="SemiBold"
                           Foreground="#EF4444"
                           Visibility="Collapsed"
                           HorizontalAlignment="Center"/>

                <!-- ── 비밀번호 입력 ── -->
                <Border Grid.Row="6" Style="{StaticResource InputBoxBorderStyle}">
                    <Grid>
                        <!-- 비밀번호 숨김 상태 -->
                        <PasswordBox x:Name="txtPassword"
                                     FontSize="24" FontFamily="Arial"
                                     Background="Transparent" BorderThickness="0"
                                     VerticalContentAlignment="Center"
                                     Padding="18,0,52,0"
                                     Foreground="{StaticResource TextDark}"
                                     GotKeyboardFocus="PasswordBox_GotFocus"
                                     PreviewKeyUp="PasswordBox_PreviewKeyUp"
                                     LostKeyboardFocus="PasswordBox_HideCaps">
                            <PasswordBox.InputBindings>
                                <KeyBinding Key="Enter"
                                            Command="{Binding UnlockCommand}"
                                            CommandParameter="{Binding ElementName=txtPassword}"/>
                            </PasswordBox.InputBindings>
                        </PasswordBox>

                        <!-- 비밀번호 표시 상태 -->
                        <TextBox x:Name="txtPasswordVisible"
                                 FontSize="24" FontFamily="Arial"
                                 Background="Transparent" BorderThickness="0"
                                 VerticalContentAlignment="Center"
                                 Padding="18,0,52,0"
                                 Foreground="{StaticResource TextDark}"
                                 Visibility="Collapsed"/>

                        <!-- 눈 버튼 -->
                        <Button x:Name="BtnShowPassword"
                                Width="64" Height="64"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,6,0"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                PreviewMouseDown="BtnShowPassword_MouseDown"
                                PreviewMouseUp="BtnShowPassword_MouseUp">
                            <TextBlock Text="👁" FontSize="30"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- ── UNLOCK 버튼 ── -->
                <Button Grid.Row="8"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding UnlockCommand}"
                        CommandParameter="{Binding ElementName=txtPassword}">
                    <TextBlock Text="UNLOCK"/>
                </Button>

            </Grid>
        </Grid>
    </Border>
</Window>

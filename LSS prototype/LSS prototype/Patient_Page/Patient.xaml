<UserControl x:Class="LSS_prototype.Patient_Page.Patient"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:LSS_prototype.Patient_Page"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             FontFamily="Arial"
             Background="#F3F5F7"
             d:DesignWidth="1920" d:DesignHeight="1080">

    <UserControl.DataContext>
        <local:PatientViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <SolidColorBrush x:Key="Primary"     Color="#173753"/>
        <SolidColorBrush x:Key="PrimaryFade" Color="#3B82F6"/>
        <SolidColorBrush x:Key="Surface"     Color="#FFFFFF"/>
        <SolidColorBrush x:Key="CardOuter"   Color="#E9ECF0"/>
        <SolidColorBrush x:Key="Border"      Color="#D6DEE8"/>
        <SolidColorBrush x:Key="TextDark"    Color="#1E293B"/>
        <SolidColorBrush x:Key="TextMid"     Color="#475569"/>
        <SolidColorBrush x:Key="TextMuted"   Color="#94A3B8"/>
        <SolidColorBrush x:Key="Panel"       Color="#0F2637"/>

        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource Surface}"/>
            <Setter Property="Foreground"      Value="{StaticResource Primary}"/>
            <Setter Property="FontSize"        Value="20"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="72"/>
            <Setter Property="Width"           Value="200"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavBtnActive" TargetType="Button" BasedOn="{StaticResource NavBtn}">
            <Setter Property="Background" Value="{StaticResource PrimaryFade}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border Background="Black" Opacity="0.2" CornerRadius="12" Margin="0,2,0,-2"/>
                            <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" CornerRadius="12">
                                <StackPanel VerticalAlignment="Center">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Border Width="40" Height="3" Background="White" Margin="0,4,0,0" CornerRadius="1.5"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ExitBtn" TargetType="Button" BasedOn="{StaticResource NavBtn}">
            <Setter Property="Width"      Value="228"/>
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="CardItem" TargetType="ListBoxItem">
            <Setter Property="Margin"           Value="10"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Outer" CornerRadius="16" BorderThickness="3" BorderBrush="Transparent" Padding="2">
                            <Border x:Name="Inner" Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}"
                                    BorderThickness="1.5" CornerRadius="14" Padding="22,18">
                                <ContentPresenter/>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Outer" Property="BorderBrush" Value="{StaticResource Primary}"/>
                                <Setter TargetName="Inner" Property="Background"  Value="#CC111827"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="90"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="256"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.Column="0" Background="#F3F5F7">
            <Grid Margin="32,24,24,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock FontSize="54" FontWeight="Bold" Foreground="{StaticResource Primary}" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{Binding PageTitle}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding PageTitle}" Value="{x:Null}">
                                        <Setter Property="Text" Value="Integrated Patient"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">

                        <CheckBox x:Name="AllPatientCheckBox" 
                  IsChecked="{Binding ShowAll, Mode=TwoWay}"
                  VerticalAlignment="Center" Margin="0,0,15,0" Cursor="Hand">
                            <CheckBox.Template>
                                <ControlTemplate TargetType="CheckBox">
                                    <Grid>
                                        <Border x:Name="Background" Width="180" Height="54" Background="#E2E8F0" CornerRadius="27">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="ALL" Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center" 
                                           FontSize="18" FontWeight="Bold" Foreground="#64748B"/>
                                                <TextBlock Text="EMR" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" 
                                           FontSize="18" FontWeight="Bold" Foreground="#64748B"/>
                                            </Grid>
                                        </Border>

                                        <Border x:Name="SelectionThumb" Width="86" Height="46" Background="White" CornerRadius="23" 
                                HorizontalAlignment="Left" Margin="4,0,0,0">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.2"/>
                                            </Border.Effect>
                                            <TextBlock x:Name="TxtSelected" Text="ALL" VerticalAlignment="Center" HorizontalAlignment="Center" 
                                       FontSize="18" FontWeight="Bold" Foreground="#1D4ED8"/>
                                            <Border.RenderTransform>
                                                <TranslateTransform x:Name="ThumbTranslate" X="0"/>
                                            </Border.RenderTransform>
                                        </Border>
                                    </Grid>

                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Background" Property="Background" Value="#DBEAFE"/>
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="ThumbTranslate" Storyboard.TargetProperty="X"
                                                         To="0" Duration="0:0:0.2"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                        </Trigger>

                                        <Trigger Property="IsChecked" Value="False">
                                            <Setter TargetName="Background" Property="Background" Value="#FEE2E2"/>
                                            <Setter TargetName="TxtSelected" Property="Text" Value="EMR"/>
                                            <Setter TargetName="TxtSelected" Property="Foreground" Value="#B91C1C"/>
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="ThumbTranslate" Storyboard.TargetProperty="X"
                                                         To="86" Duration="0:0:0.2"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </CheckBox.Template>
                        </CheckBox>

                        <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}"
                BorderThickness="1.5" CornerRadius="10" Height="54" Width="440">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="52"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="#F1F5F9" CornerRadius="9,0,0,9">
                                    <TextBlock Text="🔍" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource Primary}"/>
                                </Border>
                                <Grid Grid.Column="1">
                                    <TextBlock x:Name="PlaceholderText" Text="Search patients..." FontSize="17" Foreground="{StaticResource TextMuted}"
                               VerticalAlignment="Center" Margin="14,0,0,0" IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, ElementName=txtSearch}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBox x:Name="txtSearch" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="17" BorderThickness="0" Background="Transparent" Padding="14,0,0,0"
                             VerticalContentAlignment="Center" Foreground="{StaticResource TextDark}" xml:lang="ko-KR"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1" Background="{StaticResource CardOuter}" BorderBrush="{StaticResource Border}"
                        BorderThickness="1.5" CornerRadius="18" Padding="12">
                    <ListBox x:Name="PatientListBox" ItemsSource="{Binding Patients}" SelectedItem="{Binding SelectedPatient}"
                             Background="Transparent" BorderThickness="0" ItemContainerStyle="{StaticResource CardItem}"
                             HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="3" VerticalAlignment="Top"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top">
                                        <TextBlock x:Name="TxtName" Text="{Binding PatientName}" FontSize="26" FontWeight="Bold" Foreground="{StaticResource TextDark}"/>
                                        <TextBlock x:Name="TxtCode" Text="{Binding PatientCode}" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextMid}" Margin="0,5,0,0"/>
                                        <TextBlock x:Name="TxtInfo" FontSize="20" Foreground="{StaticResource TextMid}" Margin="0,8,0,0">
                                            <Run Text="{Binding BirthDate, StringFormat=yyyy-MM-dd}"/>
                                            <Run Text="  ·  "/>
                                            <Run Text="{Binding Sex}"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <Border x:Name="SourceBadge" CornerRadius="6" BorderThickness="1" Padding="12,5"
                                            HorizontalAlignment="Right" VerticalAlignment="Top" Background="#FEE2E2" BorderBrush="#FCA5A5">
                                        <TextBlock x:Name="TxtSourceLabel" Text="EMR" FontSize="21" FontWeight="SemiBold" Foreground="#B91C1C"/>
                                    </Border>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding AccessionNumber}" Value="{x:Null}">
                                        <Setter TargetName="SourceBadge" Property="Background"  Value="#EFF6FF"/>
                                        <Setter TargetName="SourceBadge" Property="BorderBrush" Value="#BFDBFE"/>
                                        <Setter TargetName="TxtSourceLabel" Property="Foreground" Value="#1D4ED8"/>
                                        <Setter TargetName="TxtSourceLabel" Property="Text"       Value="LOCAL"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding AccessionNumber}" Value="">
                                        <Setter TargetName="SourceBadge" Property="Background"  Value="#EFF6FF"/>
                                        <Setter TargetName="SourceBadge" Property="BorderBrush" Value="#BFDBFE"/>
                                        <Setter TargetName="TxtSourceLabel" Property="Foreground" Value="#1D4ED8"/>
                                        <Setter TargetName="TxtSourceLabel" Property="Text"       Value="LOCAL"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                        <Setter TargetName="TxtName" Property="Foreground" Value="White"/>
                                        <Setter TargetName="TxtCode" Property="Foreground" Value="#CBD5E1"/>
                                        <Setter TargetName="TxtInfo" Property="Foreground" Value="#94A3B8"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="0" Grid.Column="1" Background="{StaticResource Panel}">
            <StackPanel Margin="14,32,14,14">
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,20">
                    <TextBlock Text="LSS" FontSize="28" FontWeight="Bold" Foreground="White"/>
                    <Border Height="2" Width="44" Background="#2A6496" Margin="0,8,0,0"/>
                </StackPanel>

                <Border Background="#132E43" BorderBrush="#244A66" BorderThickness="1" CornerRadius="12" Padding="14,12" Margin="0,0,0,20" Cursor="Hand"
                        MouseLeftButtonUp="SelectedPatientBorder_Click">
                    <StackPanel>
                        <TextBlock Text="Selected Patient" Foreground="#BBD0E1" FontSize="13" Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding SelectedPatient.PatientName}" Foreground="White" FontSize="18" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding SelectedPatient.PatientCode}" Foreground="#D3E0EA" FontSize="14" Margin="0,5,0,0" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>

                <Button Style="{StaticResource NavBtn}" Command="{Binding PatientAddCommand}" Content="Add Patient" Width="228" Margin="0,0,0,18"/>
                <Button Style="{StaticResource NavBtn}" Command="{Binding PatientEditCommand}" Content="Edit Patient" Width="228" Margin="0,0,0,18"/>
                <Button Style="{StaticResource NavBtn}" Command="{Binding PatientDeleteCommand}" Content="Delete Patient" Width="228" Margin="0,0,0,18"/>
                <Button Style="{StaticResource NavBtn}" Command="{Binding EmrSyncCommand}" Content="Sync" Width="228" Margin="0,0,0,18"/>
                <Button Style="{StaticResource NavBtn}" Click="HomeButton_Click" Content="Home" Width="228"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Grid.ColumnSpan="2" Background="{StaticResource Panel}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="256"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="16,0" VerticalAlignment="Center">
                <Button Content="Patient" Style="{StaticResource NavBtnActive}" Margin="0,0,10,0"/>
                <Button Content="Scan" Style="{StaticResource NavBtn}" Command="{Binding NavScanCommand}" Margin="0,0,10,0" />
                <Button Content="Image Review" Style="{StaticResource NavBtn}" Command="{Binding NavImageReviewCommand}" Margin="0,0,10,0" />
                <Button Content="Video Review" Style="{StaticResource NavBtn}" Command="{Binding NavVideoReviewCommand}" />
            </StackPanel>
            <Button Grid.Column="1" Content="EXIT" Style="{StaticResource ExitBtn}" Click="Exit_Click" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>
    </Grid>
</UserControl>
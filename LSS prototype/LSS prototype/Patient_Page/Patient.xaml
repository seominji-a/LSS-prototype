<UserControl x:Class="LSS_prototype.Patient_Page.Patient"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:LSS_prototype.Patient_Page"
             xmlns:common="clr-namespace:LSS_prototype.Common_Module"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             FontFamily="Arial"
             Background="#F3F5F7"
             d:DesignWidth="1920" d:DesignHeight="1080">

    <UserControl.Resources>
        <SolidColorBrush x:Key="Primary"     Color="#173753"/>
        <SolidColorBrush x:Key="PrimaryFade" Color="#3B82F6"/>
        <SolidColorBrush x:Key="Surface"     Color="#FFFFFF"/>
        <SolidColorBrush x:Key="CardOuter"   Color="#E9ECF0"/>
        <SolidColorBrush x:Key="Border"      Color="#D6DEE8"/>
        <SolidColorBrush x:Key="TextDark"    Color="#1E293B"/>
        <SolidColorBrush x:Key="TextMid"     Color="#475569"/>
        <SolidColorBrush x:Key="TextMuted"   Color="#94A3B8"/>
        <SolidColorBrush x:Key="Panel"       Color="#0F2637"/>

        <!-- ★ BoolToVisibilityConverter 등록 -->
        <common:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource Surface}"/>
            <Setter Property="Foreground"      Value="{StaticResource Primary}"/>
            <Setter Property="FontSize"        Value="20"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="72"/>
            <Setter Property="Width"           Value="200"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavBtnActive" TargetType="Button" BasedOn="{StaticResource NavBtn}">
            <Setter Property="Background" Value="{StaticResource PrimaryFade}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border Background="Black" Opacity="0.2" CornerRadius="12" Margin="0,2,0,-2"/>
                            <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" CornerRadius="12">
                                <StackPanel VerticalAlignment="Center">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Border Width="40" Height="3" Background="White" Margin="0,4,0,0" CornerRadius="1.5"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ExitBtn" TargetType="Button" BasedOn="{StaticResource NavBtn}">
            <Setter Property="Width"      Value="Auto"/>
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="CardItem" TargetType="ListBoxItem">
            <Setter Property="Margin"           Value="10"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Outer" CornerRadius="16" BorderThickness="3" BorderBrush="Transparent" Padding="2">
                            <Border x:Name="Inner" Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}"
                                    BorderThickness="1.5" CornerRadius="14" Padding="22,18">
                                <ContentPresenter/>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Outer" Property="BorderBrush" Value="{StaticResource Primary}"/>
                                <Setter TargetName="Inner" Property="Background"  Value="#CC111827"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Width="140" Height="52" Cursor="Hand">
                            <Border x:Name="Track" CornerRadius="26"
                                    Background="#16A34A" Width="140" Height="52"/>
                            <TextBlock x:Name="TxtOff" Text="EMR"
                                       FontSize="20" FontWeight="Bold" FontFamily="Arial"
                                       Foreground="White"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       Margin="0,0,16,0"/>
                            <TextBlock x:Name="TxtOn" Text="LOCAL"
                                       FontSize="20" FontWeight="Bold" FontFamily="Arial"
                                       Foreground="White" Opacity="0"
                                       HorizontalAlignment="Left" VerticalAlignment="Center"
                                       Margin="16,0,0,0"/>
                            <Border x:Name="Thumb" Width="44" Height="44"
                                    CornerRadius="22" Background="White"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Left" Margin="4,0,0,0">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="ThumbTranslate" X="0"/>
                                </Border.RenderTransform>
                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="1" BlurRadius="6" Opacity="0.3"/>
                                </Border.Effect>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="Track"
                                                            Storyboard.TargetProperty="Background.Color"
                                                            To="#3B82F6" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTranslate"
                                                             Storyboard.TargetProperty="X"
                                                             To="88" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="TxtOff"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="TxtOn"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="Track"
                                                            Storyboard.TargetProperty="Background.Color"
                                                            To="#16A34A" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTranslate"
                                                             Storyboard.TargetProperty="X"
                                                             To="0" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="TxtOn"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="TxtOff"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="90"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="256"/>
        </Grid.ColumnDefinitions>

        <!-- ══ 좌측: 환자 목록 ══ -->
        <Border Grid.Row="0" Grid.Column="0" Background="#F3F5F7">
            <Grid Margin="32,24,24,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 헤더 -->
                <Grid Grid.Row="0" Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="440"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" FontSize="54" FontWeight="Bold"
                               Foreground="{StaticResource Primary}" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{Binding PageTitle}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding PageTitle}" Value="{x:Null}">
                                        <Setter Property="Text" Value="Integrated Patient"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <CheckBox Grid.Column="1"
                              x:Name="AllPatientCheckBox"
                              VerticalAlignment="Center"
                              Margin="0,0,16,0"
                              IsChecked="{Binding ShowAll, Mode=TwoWay}"
                              Style="{StaticResource ToggleSwitch}"/>

                    <Border Grid.Column="2" Background="{StaticResource Surface}"
                            BorderBrush="{StaticResource Border}" BorderThickness="1.5"
                            CornerRadius="10" Height="52">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="52"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Background="#F1F5F9" CornerRadius="9,0,0,9">
                                <TextBlock Text="🔍" FontSize="16"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{StaticResource Primary}"/>
                            </Border>
                            <Grid Grid.Column="1">
                                <TextBlock x:Name="PlaceholderText" Text="Search patients..."
                                           FontSize="17" Foreground="{StaticResource TextMuted}"
                                           VerticalAlignment="Center" Margin="14,0,0,0"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=txtSearch}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBox x:Name="txtSearch"
                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="17" BorderThickness="0" Background="Transparent"
                                         Padding="14,0,0,0" VerticalContentAlignment="Center"
                                         Foreground="{StaticResource TextDark}"
                                         CaretBrush="{StaticResource Primary}"
                                         xml:lang="ko-KR"/>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <!-- 환자 카드 리스트 -->
                <Border Grid.Row="1" Background="{StaticResource CardOuter}"
                        BorderBrush="{StaticResource Border}" BorderThickness="1.5"
                        CornerRadius="18" Padding="12">
                    <ListBox x:Name="PatientListBox"
                             ItemsSource="{Binding Patients}"
                             SelectedItem="{Binding SelectedPatient}"
                             Background="Transparent" BorderThickness="0"
                             ItemContainerStyle="{StaticResource CardItem}"
                             HorizontalContentAlignment="Stretch"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.PanningMode="VerticalOnly"
                             ScrollViewer.CanContentScroll="False">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="3" VerticalAlignment="Top"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top">
                                        <TextBlock x:Name="TxtName" Text="{Binding DisplayName, Mode=OneWay}"
                                                   FontSize="26" FontWeight="Bold"
                                                   Foreground="{StaticResource TextDark}"/>
                                        <TextBlock x:Name="TxtCode" Text="{Binding PatientCode}"
                                                   FontSize="20" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextMid}" Margin="0,5,0,0"/>
                                        <TextBlock x:Name="TxtInfo" FontSize="20"
                                                   Foreground="{StaticResource TextMid}" Margin="0,8,0,0">
                                            <Run Text="{Binding BirthDate, StringFormat=yyyy-MM-dd}"/>
                                            <Run Text="  ·  "/>
                                            <Run Text="{Binding Sex}"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- EMR / LOCAL 배지 -->
                                    <Border x:Name="SourceBadge" CornerRadius="6" BorderThickness="1" Padding="12,5"
                                            HorizontalAlignment="Right" VerticalAlignment="Top"
                                            Background="#DCFCE7" BorderBrush="#86EFAC">
                                        <TextBlock x:Name="TxtSourceLabel" Text="EMR"
                                                   FontSize="21" FontWeight="SemiBold" Foreground="#15803D"/>
                                    </Border>

                                    <!-- Description - 우측 하단 -->
                                    <TextBlock x:Name="TxtDescription"
                                               Text="{Binding RequestedProcedureDescription}"
                                               Visibility="{Binding DataContext.DescriptionVisibility,
                                                            RelativeSource={RelativeSource AncestorType=ListBox}}"
                                               HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                               FontSize="17" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextMid}"
                                               Margin="0,0,4,4"/>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Source}" Value="Emr">
                                        <Setter TargetName="SourceBadge"    Property="Background"  Value="#DCFCE7"/>
                                        <Setter TargetName="SourceBadge"    Property="BorderBrush" Value="#86EFAC"/>
                                        <Setter TargetName="TxtSourceLabel" Property="Foreground"  Value="#15803D"/>
                                        <Setter TargetName="TxtSourceLabel" Property="Text"        Value="EMR"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Source}" Value="Local">
                                        <Setter TargetName="SourceBadge"    Property="Background"  Value="#EFF6FF"/>
                                        <Setter TargetName="SourceBadge"    Property="BorderBrush" Value="#BFDBFE"/>
                                        <Setter TargetName="TxtSourceLabel" Property="Foreground"  Value="#1D4ED8"/>
                                        <Setter TargetName="TxtSourceLabel" Property="Text"        Value="LOCAL"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Source}" Value="ESync">
                                        <Setter TargetName="SourceBadge"    Property="Background"  Value="#DCFCE7"/>
                                        <Setter TargetName="SourceBadge"    Property="BorderBrush" Value="#86EFAC"/>
                                        <Setter TargetName="TxtSourceLabel" Property="Foreground"  Value="#15803D"/>
                                        <Setter TargetName="TxtSourceLabel" Property="Text"        Value="E-SYNC"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                        <Setter TargetName="TxtName"        Property="Foreground" Value="White"/>
                                        <Setter TargetName="TxtCode"        Property="Foreground" Value="#CBD5E1"/>
                                        <Setter TargetName="TxtInfo"        Property="Foreground" Value="#94A3B8"/>
                                        <Setter TargetName="TxtDescription" Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </Grid>
        </Border>

        <!-- ══ 우측 사이드 패널 ══ -->
        <Border Grid.Row="0" Grid.Column="1" Background="{StaticResource Panel}">
            <StackPanel Margin="14,32,14,14">

                <!-- LSS 로고 -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,20">
                    <TextBlock Text="LSS" FontSize="28" FontWeight="Bold" Foreground="White"/>
                    <Border Height="2" Width="44" Background="#2A6496" Margin="0,8,0,0"/>
                </StackPanel>

                <!-- ══ Selected Patient 카드 ══ -->
                <Border Background="#132E43" BorderBrush="#244A66" BorderThickness="1"
                    CornerRadius="12" Padding="14,12" Margin="0,0,0,20" Cursor="Hand"
                    MouseLeftButtonUp="SelectedPatientBorder_Click" Height="180">
                    <StackPanel>

                        <!-- ★ SelectedPatient=null이면 Hidden (공간 유지, 안 보임) -->
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedPatient}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Hidden"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <!-- 이름 -->
                            <TextBlock Text="{Binding SelectedPatient.DisplayName, Mode=OneWay}"
                       Foreground="White" FontSize="20" FontWeight="Bold"
                       TextTrimming="CharacterEllipsis"
                       Margin="0,0,0,6"/>

                            <!-- 환자번호 (PatientCode) -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="{Binding SelectedPatient.PatientCode}"
                           Foreground="White" FontSize="14"/>
                                <TextBlock Text=" (PatientCode)"
                           Foreground="White" FontSize="14"/>
                            </StackPanel>

                            <!-- 접수번호 (AccessionNumber) - 없으면 Hidden -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAccessionNumberVisible}" Value="False">
                                                <Setter Property="Visibility" Value="Hidden"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="{Binding SelectedPatient.AccessionNumber}"
                           Foreground="White" FontSize="14"/>
                                <TextBlock Text=" (AccessionNumber)"
                           Foreground="White" FontSize="14"/>
                            </StackPanel>

                            <!-- 성별 -->
                            <TextBlock Text="{Binding SelectedPatient.Sex}"
                       Foreground="White" FontSize="14"
                       Margin="0,0,0,4"/>

                            <!-- 생년월일 -->
                            <TextBlock Text="{Binding SelectedPatient.BirthDate, StringFormat=yyyy-MM-dd}"
                       Foreground="White" FontSize="14"
                       Margin="0,0,0,4"/>

                            <!-- Description - DescriptionVisibility=Hidden이면 공간 유지하며 숨김 -->
                            <TextBlock Text="{Binding SelectedPatient.RequestedProcedureDescription}"
                       Foreground="White" FontSize="14" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 버튼들 -->
                <Button Style="{StaticResource NavBtn}" Command="{Binding PatientAddCommand}"
                        Content="Add Patient" Width="228" Margin="0,0,0,18"/>
                <Button Style="{StaticResource NavBtn}" Command="{Binding PatientEditCommand}"
                        Content="Edit Patient" Width="228" Margin="0,0,0,18"/>
                <Button Style="{StaticResource NavBtn}" Command="{Binding PatientDeleteCommand}"
                        Content="Delete Patient" Width="228" Margin="0,0,0,18"/>
                <Button Style="{StaticResource NavBtn}" Command="{Binding EmrSyncCommand}"
                        Content="Sync" Width="228" Margin="0,0,0,18"/>
                <Button Style="{StaticResource NavBtn}" Command="{Binding ImportCommand}"
                        Content="Import" Width="228" Margin="0,0,0,18"/>
                <Button Style="{StaticResource NavBtn}" Click="HomeButton_Click" x:Name="HomeButton"
                        Content="Home" Width="228"/>
            </StackPanel>
        </Border>

        <!-- ══ 하단 네비게이션 바 ══ -->
        <Grid Grid.Row="1" Grid.ColumnSpan="2" Background="{StaticResource Panel}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="16,0" VerticalAlignment="Center">
                <Button Content="Patient"      Style="{StaticResource NavBtnActive}" Margin="0,0,10,0"/>
                <Button Content="Scan"         Style="{StaticResource NavBtn}"       Command="{Binding NavScanCommand}"        Margin="0,0,10,0"/>
                <Button Content="Image Review" Style="{StaticResource NavBtn}"       Command="{Binding NavImageReviewCommand}" Margin="0,0,10,0"/>
                <Button Content="Video Review" Style="{StaticResource NavBtn}"       Command="{Binding NavVideoReviewCommand}"/>
            </StackPanel>

        </Grid>

        <!-- 전원 메뉴 버튼 오버레이 (우하단 고정) -->
        <Grid Grid.Row="0" Grid.Column="1"
                    Grid.RowSpan="2"
                    Panel.ZIndex="99"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,20,15"
                    x:Name="MenuButtonArea">
            <Button x:Name="MenuToggleBtn"
                    Style="{StaticResource MenuToggleStyle}"
                    Command="{Binding ToggleMenuCommand}">
                <TextBlock Text="⏻" FontSize="35"/>
            </Button>
            <Popup x:Name="MenuPopup"
                   IsOpen="{Binding IsMenuOpen, Mode=TwoWay}"
                   PlacementTarget="{Binding ElementName=MenuToggleBtn}"
                   Placement="Top"
                   StaysOpen="False"
                   AllowsTransparency="True"
                   PopupAnimation="Fade">
                <Border Background="#1F2937" CornerRadius="10"
                        Padding="6" Margin="0,0,0,6">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.4"
                                          BlurRadius="12" ShadowDepth="4" Direction="270"/>
                    </Border.Effect>
                    <StackPanel MinWidth="200">
                        <!-- Lock -->
                        <Button Style="{StaticResource PopupMenuItemBtn}"
                                Command="{Binding LockCommand}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="22" Width="36" TextAlignment="Center"
                                           VerticalAlignment="Center" Margin="0,0,14,0"/>
                                <TextBlock Text="Lock" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <!-- Log Out -->
                        <Button Style="{StaticResource PopupMenuItemBtn}"
                                Command="{Binding LogoutCommand}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#xF3B1;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="22" Width="36" TextAlignment="Center"
                                           VerticalAlignment="Center" Margin="0,0,14,0"/>
                                <TextBlock Text="Log Out" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <!-- Exit -->
                        <Button Style="{StaticResource PopupMenuItemBtn}"
                                Command="{Binding ExitCommand}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#xE7E8;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="22" Width="36" TextAlignment="Center"
                                           VerticalAlignment="Center" Margin="0,0,14,0"/>
                                <TextBlock Text="Exit" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>
    </Grid>
</UserControl>

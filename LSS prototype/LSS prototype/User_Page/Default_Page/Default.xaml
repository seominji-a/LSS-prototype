<Window x:Class="LSS_prototype.User_Page.Default"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Default Settings"
        WindowState="Maximized"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Width="720" Height="820">

    <Window.Resources>
        <!-- ✅ Login 톤 색상 -->
        <SolidColorBrush x:Key="Bg"           Color="#F3F5F7"/>
        <SolidColorBrush x:Key="Primary"      Color="#173753"/>
        <SolidColorBrush x:Key="PrimaryHover" Color="#1F4767"/>
        <SolidColorBrush x:Key="Secondary"    Color="#5F6E82"/>
        <SolidColorBrush x:Key="TextDark"     Color="#1E293B"/>
        <SolidColorBrush x:Key="TextMuted"    Color="#64748B"/>
        <SolidColorBrush x:Key="InputBg"      Color="#FFFFFF"/>
        <SolidColorBrush x:Key="InputBorder"  Color="#D6DEE8"/>
        <SolidColorBrush x:Key="CardBg"       Color="#FFFFFF"/>
        <SolidColorBrush x:Key="ValueBg"      Color="#EEF2F7"/>
        <SolidColorBrush x:Key="BtnDark"      Color="#E2E8F0"/>
        <SolidColorBrush x:Key="Accent"       Color="#173753"/>
        <SolidColorBrush x:Key="ToggleOn"     Color="#173753"/>
        <SolidColorBrush x:Key="ToggleOff"    Color="#D6DEE8"/>

        <Style x:Key="BaseBtn" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="14.4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PmBtn" TargetType="RepeatButton">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="{TemplateBinding Background}" CornerRadius="14.4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Background" Value="{StaticResource Primary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize"   Value="31.2"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Width"      Value="76.8"/>
            <Setter Property="Height"     Value="76.8"/>
        </Style>

        <Style x:Key="ActionBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize"   Value="16.8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height"     Value="52.8"/>
        </Style>

        <Style x:Key="ToggleBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="FontSize"    Value="15.6"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Width"       Value="91.2"/>
            <Setter Property="Height"      Value="52.8"/>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- ✅ 반투명 오버레이 - 뒷배경 터치 차단 -->
        <Grid Background="#7F000000"/>

        <!-- ✅ 중앙 팝업 내용 -->
        <Border Background="{StaticResource Bg}"
                CornerRadius="19.2"
                Padding="24,19.2,24,21.6"
                Width="624"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="28.8" ShadowDepth="4.8" Opacity="0.15" Color="#173753"/>
            </Border.Effect>

            <StackPanel>
                <!-- ── 타이틀 바 ── -->
                <Grid Margin="0,0,0,14.4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Default Settings"
                                   Foreground="{StaticResource Primary}" FontSize="21.6" FontWeight="Bold"/>
                        <TextBlock Text="Camera Default Setting"
                                   Foreground="{StaticResource TextMuted}" FontSize="14.4" Margin="0,2.4,0,0"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Width="43.2" Height="43.2"
                            Background="#E2E8F0"
                            Style="{StaticResource BaseBtn}" Click="Button_Click">
                        <TextBlock Text="✕" Foreground="{StaticResource TextMuted}" FontSize="19.2" FontWeight="Bold"/>
                    </Button>
                </Grid>

                <!-- ── 구분선 ── -->
                <Border Height="1.2" Background="{StaticResource InputBorder}" Margin="0,0,0,14.4"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="9.6"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="11.5"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="11.5"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="11.5"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- ── EXPOSURE TIME (좌, Row 0) ── -->
                    <Border Grid.Column="0" Grid.Row="0"
                            Background="{StaticResource CardBg}" CornerRadius="12" Padding="12,9.6"
                            BorderBrush="{StaticResource InputBorder}" BorderThickness="1.5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="7.2"/>
                                <RowDefinition Height="92.2"/>
                                <RowDefinition Height="4.3"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="EXPOSURE TIME"
                                       Foreground="{StaticResource TextDark}" FontSize="13.2" FontWeight="Bold"/>
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1.1*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <RepeatButton Delay="500" Interval="80" Grid.Column="0" Content="-" Style="{StaticResource PmBtn}"
                                              Margin="0,0,7.2,0" Command="{Binding ExposureDecCommand}"/>
                                <Border Grid.Column="1" Background="{StaticResource ValueBg}" CornerRadius="9.6">
                                    <TextBlock Text="{Binding ExposureText}"
                                               Foreground="{StaticResource TextDark}" FontSize="23" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <RepeatButton Delay="500" Interval="80" Grid.Column="2" Content="+" Style="{StaticResource PmBtn}"
                                              Margin="7.2,0,0,0" Command="{Binding ExposureIncCommand}"/>
                            </Grid>
                            <TextBlock Grid.Row="4" Text="0.1s ~ 1.0s"
                                       Foreground="{StaticResource TextMuted}" FontSize="12"
                                       HorizontalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- ── GAIN (우, Row 0) ── -->
                    <Border Grid.Column="2" Grid.Row="0"
                            Background="{StaticResource CardBg}" CornerRadius="12" Padding="12,9.6"
                            BorderBrush="{StaticResource InputBorder}" BorderThickness="1.5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="7.2"/>
                                <RowDefinition Height="92.2"/>
                                <RowDefinition Height="4.3"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="GAIN"
                                       Foreground="{StaticResource TextDark}" FontSize="13.2" FontWeight="Bold"/>
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1.1*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <RepeatButton Delay="500" Interval="80" Grid.Column="0" Content="-" Style="{StaticResource PmBtn}"
                                              Margin="0,0,7.2,0" Command="{Binding GainDecCommand}"/>
                                <Border Grid.Column="1" Background="{StaticResource ValueBg}" CornerRadius="9.6">
                                    <TextBlock Text="{Binding GainValue}"
                                               Foreground="{StaticResource TextDark}" FontSize="33.6" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <RepeatButton Delay="500" Interval="80" Grid.Column="2" Content="+" Style="{StaticResource PmBtn}"
                                              Margin="7.2,0,0,0" Command="{Binding GainIncCommand}"/>
                            </Grid>
                            <TextBlock Grid.Row="4" Text="3dB ~ 30dB"
                                       Foreground="{StaticResource TextMuted}" FontSize="12"
                                       HorizontalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- ── GAMMA (좌, Row 2) ── -->
                    <Border Grid.Column="0" Grid.Row="2"
                            Background="{StaticResource CardBg}" CornerRadius="12" Padding="12,9.6"
                            BorderBrush="{StaticResource InputBorder}" BorderThickness="1.5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="7.2"/>
                                <RowDefinition Height="92.2"/>
                                <RowDefinition Height="4.3"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="GAMMA"
                                       Foreground="{StaticResource TextDark}" FontSize="13.2" FontWeight="Bold"/>
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1.1*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <RepeatButton Delay="500" Interval="80" Grid.Column="0" Content="-" Style="{StaticResource PmBtn}"
                                              Margin="0,0,7.2,0" Command="{Binding GammaDecCommand}"/>
                                <Border Grid.Column="1" Background="{StaticResource ValueBg}" CornerRadius="9.6">
                                    <TextBlock Text="{Binding GammaValue}"
                                               Foreground="{StaticResource TextDark}" FontSize="33.6" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <RepeatButton Delay="500" Interval="80" Grid.Column="2" Content="+" Style="{StaticResource PmBtn}"
                                              Margin="7.2,0,0,0" Command="{Binding GammaIncCommand}"/>
                            </Grid>
                            <TextBlock Grid.Row="4" Text="0.3 ~ 1"
                                       Foreground="{StaticResource TextMuted}" FontSize="12"
                                       HorizontalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- ── FOCUS (우, Row 2) ── -->
                    <Border Grid.Column="2" Grid.Row="2"
                            Background="{StaticResource CardBg}" CornerRadius="12" Padding="12,9.6"
                            BorderBrush="{StaticResource InputBorder}" BorderThickness="1.5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="7.2"/>
                                <RowDefinition Height="92.2"/>
                                <RowDefinition Height="4.3"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="FOCUS"
                                       Foreground="{StaticResource TextDark}" FontSize="13.2" FontWeight="Bold"/>
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1.1*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <RepeatButton Delay="500" Interval="80" Grid.Column="0" Content="-" Style="{StaticResource PmBtn}"
                                              Margin="0,0,7.2,0" Command="{Binding FocusDecCommand}"/>
                                <Border Grid.Column="1" Background="{StaticResource ValueBg}" CornerRadius="9.6">
                                    <TextBlock Text="{Binding FocusValue}"
                                               Foreground="{StaticResource TextDark}" FontSize="33.6" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <RepeatButton Delay="500" Interval="80" Grid.Column="2" Content="+" Style="{StaticResource PmBtn}"
                                              Margin="7.2,0,0,0" Command="{Binding FocusIncCommand}"/>
                            </Grid>
                            <TextBlock Grid.Row="4" Text="3545 ~ 8310  |  Step 300"
                                       Foreground="{StaticResource TextMuted}" FontSize="12"
                                       HorizontalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- ── IRIS (좌, Row 4) ── -->
                    <Border Grid.Column="0" Grid.Row="4"
                            Background="{StaticResource CardBg}" CornerRadius="12" Padding="12,9.6"
                            BorderBrush="{StaticResource InputBorder}" BorderThickness="1.5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="7.2"/>
                                <RowDefinition Height="92.2"/>
                                <RowDefinition Height="4.3"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="IRIS"
                                       Foreground="{StaticResource TextDark}" FontSize="13.2" FontWeight="Bold"/>
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1.1*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <RepeatButton Delay="500" Interval="80" Grid.Column="0" Content="-" Style="{StaticResource PmBtn}"
                                              Margin="0,0,7.2,0" Command="{Binding IrisDecCommand}"/>
                                <Border Grid.Column="1" Background="{StaticResource ValueBg}" CornerRadius="9.6">
                                    <TextBlock Text="{Binding IrisValue}"
                                               Foreground="{StaticResource TextDark}" FontSize="33.6" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <RepeatButton Delay="500" Interval="80" Grid.Column="2" Content="+" Style="{StaticResource PmBtn}"
                                              Margin="7.2,0,0,0" Command="{Binding IrisIncCommand}"/>
                            </Grid>
                            <TextBlock Grid.Row="4" Text="0 ~ 656  |  Step 50"
                                       Foreground="{StaticResource TextMuted}" FontSize="12"
                                       HorizontalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- ── ZOOM (우, Row 4) ── -->
                    <Border Grid.Column="2" Grid.Row="4"
                            Background="{StaticResource CardBg}" CornerRadius="12" Padding="12,9.6"
                            BorderBrush="{StaticResource InputBorder}" BorderThickness="1.5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="7.2"/>
                                <RowDefinition Height="92.2"/>
                                <RowDefinition Height="4.3"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="ZOOM"
                                       Foreground="{StaticResource TextDark}" FontSize="13.2" FontWeight="Bold"/>
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1.1*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <RepeatButton Delay="500" Interval="80" Grid.Column="0" Content="-" Style="{StaticResource PmBtn}"
                                              Margin="0,0,7.2,0" Command="{Binding ZoomDecCommand}"/>
                                <Border Grid.Column="1" Background="{StaticResource ValueBg}" CornerRadius="9.6">
                                    <TextBlock Text="{Binding ZoomValue}"
                                               Foreground="{StaticResource TextDark}" FontSize="33.6" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <RepeatButton Delay="500" Interval="80" Grid.Column="2" Content="+" Style="{StaticResource PmBtn}"
                                              Margin="7.2,0,0,0" Command="{Binding ZoomIncCommand}"/>
                            </Grid>
                            <TextBlock Grid.Row="4" Text="1138 ~ 4669  |  Step 300"
                                       Foreground="{StaticResource TextMuted}" FontSize="12"
                                       HorizontalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- ── FILTER (전체 Row 6) ── -->
                    <Border Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="6"
                            Background="{StaticResource CardBg}" CornerRadius="12" Padding="14.4,12"
                            BorderBrush="{StaticResource InputBorder}" BorderThickness="1.5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="FILTER"
                                           Foreground="{StaticResource TextDark}" FontSize="13.2" FontWeight="Bold"/>
                                <TextBlock Text="IR 필터 ON / OFF 전환"
                                           Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,3.6,0,0"/>
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Background="{StaticResource InputBorder}"
                                    CornerRadius="16.8"
                                    Padding="4.8"
                                    VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="OFF"
                                            Style="{StaticResource ToggleBtn}"
                                            Background="{Binding FilterOffBackground}"
                                            Margin="0,0,3.6,0"
                                            Command="{Binding FilterOffCommand}"/>
                                    <Button Content="ON"
                                            Style="{StaticResource ToggleBtn}"
                                            Background="{Binding FilterOnBackground}"
                                            Command="{Binding FilterOnCommand}"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ── 구분선 ── -->
                <Border Height="1.2" Background="{StaticResource InputBorder}" Margin="0,16.8,0,14.4"/>

                <!-- ── 하단 버튼: RESET / SAVE ── -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="RESET"
                            Style="{StaticResource ActionBtn}"
                            Background="#E2E8F0"
                            Foreground="{StaticResource TextMuted}"
                            Command="{Binding ResetCommand}"/>

                    <Button Grid.Column="2" Content="SAVE"
                            Style="{StaticResource ActionBtn}"
                            Background="{StaticResource Primary}"
                            Command="{Binding SaveCommand}"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>

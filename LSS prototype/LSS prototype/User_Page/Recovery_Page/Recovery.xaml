<UserControl x:Class="LSS_prototype.User_Page.Recovery"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LSS_prototype.Common_Module"
        xmlns:local_user="clr-namespace:LSS_prototype.User_Page"
        mc:Ignorable="d"
        d:DesignWidth="1920" d:DesignHeight="1080"
        FontFamily="Arial" Background="#F3F5F7">

    <UserControl.DataContext>
        <local_user:RecoveryViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>

        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <SolidColorBrush x:Key="Primary"     Color="#173753"/>
        <SolidColorBrush x:Key="PrimaryFade" Color="#3B82F6"/>
        <SolidColorBrush x:Key="Surface"     Color="#FFFFFF"/>
        <SolidColorBrush x:Key="CardOuter"   Color="#E9ECF0"/>
        <SolidColorBrush x:Key="Border"      Color="#D6DEE8"/>
        <SolidColorBrush x:Key="TextDark"    Color="#1E293B"/>
        <SolidColorBrush x:Key="TextMid"     Color="#475569"/>
        <SolidColorBrush x:Key="TextMuted"   Color="#94A3B8"/>
        <SolidColorBrush x:Key="Panel"       Color="#0F2637"/>
        <SolidColorBrush x:Key="Accent"      Color="#3B82F6"/>
        <SolidColorBrush x:Key="BtnDark"     Color="#2A3F55"/>
        <SolidColorBrush x:Key="ValueBg"     Color="#1A2D3E"/>
        <SolidColorBrush x:Key="Inactive"    Color="#94A3B8"/>

        <!-- ── NavBtn ── -->
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource Surface}"/>
            <Setter Property="Foreground"      Value="{StaticResource Primary}"/>
            <Setter Property="FontSize"        Value="18"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="62"/>
            <Setter Property="Width"           Value="228"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ExitBtn" TargetType="Button" BasedOn="{StaticResource NavBtn}">
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="RecoverBtn" TargetType="Button" BasedOn="{StaticResource NavBtn}">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Width"      Value="228"/>
            <Setter Property="Height"     Value="62"/>
        </Style>

        <!-- ── SectionLabel (User.xaml 동일) ── -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="Foreground"   Value="{StaticResource TextMuted}"/>
            <Setter Property="Margin"       Value="0,0,0,14"/>
        </Style>

        <!-- ── 컬럼 헤더 ── -->
        <!--   헤더 Thumb(사이즈 조절 핸들) 숨김 → 헤더 사이 흰 선 제거 -->
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="0"/>
        </Style>

        <Style x:Key="ColHeader" TargetType="GridViewColumnHeader">
            <Setter Property="Background"      Value="{StaticResource Primary}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontSize"        Value="15"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="12,0"/>
            <Setter Property="Height"          Value="44"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ColHeaderFirst" TargetType="GridViewColumnHeader" BasedOn="{StaticResource ColHeader}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="10,0,0,0">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--   마지막 컬럼 헤더는 Width="*" 로 남은 공간 전부 채움 -->
        <Style x:Key="ColHeaderLast" TargetType="GridViewColumnHeader" BasedOn="{StaticResource ColHeader}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="0,10,0,0">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── RowItem ── -->
        <Style x:Key="RowItem" TargetType="ListViewItem">
            <Setter Property="Margin"           Value="0,0,0,7"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Height"           Value="62"/>
            <Setter Property="Foreground"       Value="{StaticResource TextDark}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <!-- IsCheckable=False인 행은 선택 자체를 막음 -->
            <Setter Property="IsEnabled"        Value="{Binding IsCheckable}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Grid>
                            <Border x:Name="RowBorder"
                                    Background="{StaticResource Surface}"
                                    BorderBrush="{StaticResource Border}"
                                    BorderThickness="1.5"
                                    CornerRadius="0"
                                    Margin="0,2">
                                <GridViewRowPresenter VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="RowBorder" Property="Background"  Value="#CC1E3A5F"/>
                                <Setter TargetName="RowBorder" Property="BorderBrush" Value="{StaticResource Primary}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RowBorder" Property="BorderBrush" Value="{StaticResource PrimaryFade}"/>
                            </Trigger>
                            <!-- IsEnabled=False (IsCheckable=False) 인 행 공통 스타일 -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Cursor"  Value="Arrow"/>
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                            <!-- 강제삭제/만료삭제 → 빨간 배경 추가 -->
                            <DataTrigger Binding="{Binding IsForceDeleted}" Value="Y">
                                <Setter TargetName="RowBorder" Property="Background"  Value="#40E24B4A"/>
                                <Setter TargetName="RowBorder" Property="BorderBrush" Value="#80E24B4A"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Cell DataTemplate ── -->

        <!--   체크박스 셀 -->
        <DataTemplate x:Key="CheckBoxCell">
            <CheckBox IsChecked="{Binding IsChecked, UpdateSourceTrigger=PropertyChanged}"
              IsEnabled="{Binding IsCheckable}"
              Visibility="{Binding IsCheckable, Converter={StaticResource BoolToVisibilityConverter}}"
              HorizontalAlignment="Center" VerticalAlignment="Center"
              Cursor="Hand" Width="48" Height="48">
                <CheckBox.Template>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Bd"
                                Width="40" Height="40"
                                CornerRadius="6"
                                BorderThickness="2"
                                BorderBrush="#94A3B8"
                                Background="White">
                            <TextBlock x:Name="Chk"
                                       Text="&#x2713;"
                                       FontSize="40" FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd"  Property="Background"  Value="#3B82F6"/>
                                <Setter TargetName="Bd"  Property="BorderBrush" Value="#3B82F6"/>
                                <Setter TargetName="Chk" Property="Visibility"  Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3B82F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </CheckBox.Template>
            </CheckBox>
        </DataTemplate>

        <DataTemplate x:Key="PatientNameCell">
            <TextBlock Text="{Binding DisplayName}" FontSize="15" FontWeight="Bold" Margin="12,0"
                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListViewItem}}"
                       VerticalAlignment="Center"/>
        </DataTemplate>

        <DataTemplate x:Key="PatientCodeCell">
            <TextBlock Text="{Binding PatientCode}" FontSize="15" Margin="12,0"
                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListViewItem}}"
                       VerticalAlignment="Center"/>
        </DataTemplate>

        <DataTemplate x:Key="DeletedByCell">
            <TextBlock Text="{Binding DeletedBy}" FontSize="15" Margin="12,0"
                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListViewItem}}"
                       VerticalAlignment="Center"/>
        </DataTemplate>

        <DataTemplate x:Key="FileTypeCell">
            <TextBlock Text="{Binding FileType}" FontSize="15" Margin="12,0"
                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListViewItem}}"
                       VerticalAlignment="Center"/>
        </DataTemplate>

        <DataTemplate x:Key="DeletedAtCell">
            <TextBlock Text="{Binding DeletedAt}" FontSize="15" Margin="12,0"
                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListViewItem}}"
                       VerticalAlignment="Center"/>
        </DataTemplate>

        <DataTemplate x:Key="RemainCell">
            <TextBlock Text="{Binding RemainText}" FontSize="15" FontWeight="SemiBold" Margin="12,0"
                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListViewItem}}"
                       VerticalAlignment="Center"/>
        </DataTemplate>


        <!-- ── SeekSlider (VideoComment 완전 동일) ── -->
        <Style x:Key="SeekSlider" TargetType="Slider">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Height="44" Background="Transparent">
                                <Grid VerticalAlignment="Center">
                                    <Border Height="6" CornerRadius="3"
                                            Background="{StaticResource BtnDark}" Margin="22,0"/>
                                    <Track x:Name="PART_Track" Margin="0">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Command="Slider.DecreaseLarge" Focusable="False">
                                                <RepeatButton.Template>
                                                    <ControlTemplate TargetType="RepeatButton">
                                                        <Border Height="6" CornerRadius="3,0,0,3"
                                                                Background="{StaticResource Accent}"
                                                                VerticalAlignment="Center"/>
                                                    </ControlTemplate>
                                                </RepeatButton.Template>
                                            </RepeatButton>
                                        </Track.DecreaseRepeatButton>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Command="Slider.IncreaseLarge" Focusable="False">
                                                <RepeatButton.Template>
                                                    <ControlTemplate TargetType="RepeatButton">
                                                        <Border Background="Transparent"/>
                                                    </ControlTemplate>
                                                </RepeatButton.Template>
                                            </RepeatButton>
                                        </Track.IncreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb>
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Grid Width="36" Height="36">
                                                            <Ellipse Fill="#40000000" Margin="-2"/>
                                                            <Ellipse Fill="White"/>
                                                            <Ellipse Width="12" Height="12"
                                                                     Fill="{StaticResource Accent}"
                                                                     HorizontalAlignment="Center"
                                                                     VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── PlayBtn (VideoComment 완전 동일) ── -->
        <Style x:Key="PlayBtn" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource Accent}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="256"/>
        </Grid.ColumnDefinitions>

        <!-- ══ 좌측 메인 영역 ══ -->
        <Border Grid.Column="0" Background="#F3F5F7">
            <Grid Margin="24,20,16,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 헤더 -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Recovery Manager"
                               FontSize="40" FontWeight="Bold"
                               Foreground="{StaticResource Primary}"
                               VerticalAlignment="Center"/>

                    <!--   필터 콤보 (App.xaml InputComboBoxStyle) + 검색창 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">

                        <Border Width="200" Height="55" Margin="0,0,10,0"
                                Background="White" BorderBrush="#DDE2E8" BorderThickness="1.5">
                            <Border.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="10"/>
                                </Style>
                            </Border.Resources>
                            <ComboBox Style="{StaticResource InputComboBoxStyle}"
                                      ItemContainerStyle="{StaticResource InputComboBoxItemStyle}"
                                      SelectedItem="{Binding SelectedFilter}"
                                      ItemsSource="{Binding FilterOptions}"/>
                        </Border>

                        <Border Background="{StaticResource Surface}"
                                            BorderBrush="{StaticResource Border}"
                                            BorderThickness="1.5" CornerRadius="10"
                                            Width="340" Height="55">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="52"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Background="#F1F5F9" CornerRadius="9,0,0,9">
                                    <TextBlock Text="🔍" FontSize="16"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                                </Border>

                                <Grid Grid.Column="1">
                                    <TextBlock Text="환자명 / 환자코드 검색..."
                                            FontSize="15"
                                            Foreground="{StaticResource TextMuted}"
                                            VerticalAlignment="Center"
                                            Margin="14,0,0,0"
                                            IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, ElementName=txtSearch}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <TextBox x:Name="txtSearch"
                                            Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                            FontSize="15"
                                            BorderThickness="0"
                                            Background="Transparent"
                                            Padding="14,0,0,0"
                                            VerticalContentAlignment="Center"
                                            Foreground="{StaticResource TextDark}"
                                            CaretBrush="{StaticResource Primary}"
                                            xml:lang="ko-KR"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- 뷰어 + 테이블 -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="3*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 뷰어 (VideoComment 동일 스타일) -->
                    <Border Grid.Column="0" Background="Black" CornerRadius="8" ClipToBounds="True">
                        <Grid>

                            <!-- 선택 전 안내 -->
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Visibility="{Binding IsViewerEmpty, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="행을 선택하면 미리보기가 표시됩니다"
                                           Foreground="#475569" FontSize="15"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- 이미지 뷰어 -->
                            <Image Source="{Binding PreviewImageSource}" Stretch="Uniform"
                                   Visibility="{Binding IsImageVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>

                            <!-- ISF 오버레이 (읽기 전용) -->
                            <InkCanvas x:Name="PreviewDrawingCanvas"
                                       Background="Transparent"
                                       IsHitTestVisible="False"
                                       EditingMode="None"
                                       Visibility="{Binding IsImageVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>

                            <!--   파일타입 좌상단 (이미지/영상 공통) -->
                            <StackPanel Margin="16,14"
                                        VerticalAlignment="Top" HorizontalAlignment="Left"
                                        Visibility="{Binding IsViewerEmpty, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
                                <TextBlock Text="{Binding SelectedFilePath}"
                                           Foreground="White" FontSize="15" FontWeight="Bold"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding SelectedFileType}"
                                           Foreground="#BBCCE0" FontSize="15"/>
                            </StackPanel>

                            <!-- 영상 뷰어 -->
                            <MediaElement x:Name="PreviewVideo"
                                          LoadedBehavior="Manual" UnloadedBehavior="Stop"
                                          Stretch="Uniform"
                                          ScrubbingEnabled="True"
                                          Visibility="{Binding IsVideoVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                          MediaOpened="PreviewVideo_MediaOpened"
                                          MediaEnded="PreviewVideo_MediaEnded"/>

                            <!-- ── 하단 컨트롤 오버레이 (VideoComment 완전 동일 구조) ── -->
                            <Border VerticalAlignment="Bottom"
                                    Background="#CC1C2B3A"
                                    CornerRadius="0,0,8,8"
                                    Padding="16,10"
                                    Visibility="{Binding IsVideoVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <!-- Seek + 시간 -->
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="70"/>
                                        <!-- 컨트롤 한 줄 -->
                                    </Grid.RowDefinitions>

                                    <!-- Seek 슬라이더 + 시간 한 줄 (VideoComment 동일) -->
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" x:Name="TxtCurrentTime" Text="00:00"
                                                   Foreground="White" FontSize="15" FontWeight="Bold"
                                                   FontFamily="Courier New" VerticalAlignment="Center"
                                                   Margin="0,0,10,0"/>
                                        <Slider Grid.Column="1" x:Name="SliderSeek"
                                                Style="{StaticResource SeekSlider}"
                                                Minimum="0" Maximum="100" Value="0"
                                                IsMoveToPointEnabled="True"
                                                PreviewMouseDown="PreviewSlider_MouseDown"
                                                PreviewMouseUp="PreviewSlider_MouseUp"
                                                ValueChanged="PreviewSlider_ValueChanged"/>
                                        <TextBlock Grid.Column="2" x:Name="TxtTotalTime" Text="00:00"
                                                   Foreground="#94A3B8" FontSize="15"
                                                   FontFamily="Courier New" VerticalAlignment="Center"
                                                   Margin="10,0,0,0"/>
                                    </Grid>

                                    <!-- ── 컨트롤 한 줄 (VideoComment 동일 구조) ── -->
                                    <Grid Grid.Row="2">

                                        <!-- 배속 표시: 좌측 고정 (x2 고정) -->
                                        <Border HorizontalAlignment="Left" VerticalAlignment="Center"
                                                Background="#1A2D3E"
                                                CornerRadius="8" Padding="14,0" Height="44">
                                            <TextBlock x:Name="TxtSpeedLabel"
                                                       Text="x2" Foreground="White"
                                                       FontSize="16" FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- 재생/정지 버튼: 정중앙 고정 -->
                                        <Button x:Name="BtnPlayPause"
                                                Style="{StaticResource PlayBtn}"
                                                Width="100" Height="70"
                                                HorizontalAlignment="Center"
                                                Click="BtnPlayPause_Click">
                                            <Grid>
                                                <!-- 재생 아이콘 (흰색 삼각형): 정지 상태일 때 표시 -->
                                                <Viewbox x:Name="ImgPlay" Width="72" Height="72" Stretch="Uniform"
                                                         Visibility="Visible">
                                                    <Canvas Width="100" Height="100">
                                                        <Path Fill="White"
                                                              Data="M66.53,49.1l-23.98-14.23c-.7-.41-1.57.09-1.57.9v28.46c0,.81.88,1.31,1.57.9l23.98-14.23c.68-.4.68-1.39,0-1.79Z"/>
                                                    </Canvas>
                                                </Viewbox>
                                                <!-- 일시정지 아이콘 (흰색 바): 재생 중일 때 표시 -->
                                                <Viewbox x:Name="ImgPause" Width="72" Height="72" Stretch="Uniform"
                                                         Visibility="Collapsed">
                                                    <Canvas Width="100" Height="100">
                                                        <Path Fill="White"
                                                              Data="M 40.66,35.69 H 44.27 A 1.52,1.52 0 0 1 45.79,37.21 V 62.78 A 1.52,1.52 0 0 1 44.27,64.3 H 40.66 A 1.52,1.52 0 0 1 39.14,62.78 V 37.21 A 1.52,1.52 0 0 1 40.66,35.69 Z"/>
                                                        <Path Fill="White"
                                                              Data="M 55.73,35.69 H 59.34 A 1.52,1.52 0 0 1 60.86,37.21 V 62.78 A 1.52,1.52 0 0 1 59.34,64.3 H 55.73 A 1.52,1.52 0 0 1 54.21,62.78 V 37.21 A 1.52,1.52 0 0 1 55.73,35.69 Z"/>
                                                    </Canvas>
                                                </Viewbox>
                                            </Grid>
                                        </Button>

                                    </Grid>

                                </Grid>
                            </Border>

                        </Grid>
                    </Border>

                    <!--   테이블: Background=Transparent + ScrollViewer 비활성화로 흰 영역 완전 제거 -->
                    <ListView Grid.Column="2"
                              x:Name="RecoveryList"
                              ItemsSource="{Binding FilteredLogs}"
                              SelectedItem="{Binding SelectedLog}"
                              ItemContainerStyle="{StaticResource RowItem}"
                              BorderThickness="0"
                              Background="Transparent"
                              HorizontalContentAlignment="Stretch">
                        <ListView.Template>
                            <ControlTemplate TargetType="ListView">
                                <Border Background="{StaticResource CardOuter}"
                                        CornerRadius="10" ClipToBounds="True">
                                    <DockPanel>
                                        <GridViewHeaderRowPresenter
                                            DockPanel.Dock="Top"
                                            Margin="0"
                                            Columns="{Binding View.Columns, RelativeSource={RelativeSource TemplatedParent}}"
                                            ColumnHeaderContainerStyle="{Binding View.ColumnHeaderContainerStyle, RelativeSource={RelativeSource TemplatedParent}}"/>
                                        <ScrollViewer ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                      ScrollViewer.HorizontalScrollBarVisibility="Hidden">
                                            <ItemsPresenter Margin="0,8,0,10"/>
                                        </ScrollViewer>
                                    </DockPanel>
                                </Border>
                            </ControlTemplate>
                        </ListView.Template>

                        <ListView.View>
                            <GridView AllowsColumnReorder="False">
                                <!--   체크박스 컬럼 -->
                                <GridViewColumn Header="" Width="52"
                                                HeaderContainerStyle="{StaticResource ColHeaderFirst}"
                                                CellTemplate="{StaticResource CheckBoxCell}"/>
                                <GridViewColumn Header="환자명"      Width="160"
                                                HeaderContainerStyle="{StaticResource ColHeader}"
                                                CellTemplate="{StaticResource PatientNameCell}"/>
                                <GridViewColumn Header="환자코드"    Width="110"
                                                HeaderContainerStyle="{StaticResource ColHeader}"
                                                CellTemplate="{StaticResource PatientCodeCell}"/>
                                <GridViewColumn Header="삭제한 사람" Width="150"
                                                HeaderContainerStyle="{StaticResource ColHeader}"
                                                CellTemplate="{StaticResource DeletedByCell}"/>
                                <GridViewColumn Header="파일 타입"   Width="160"
                                                HeaderContainerStyle="{StaticResource ColHeader}"
                                                CellTemplate="{StaticResource FileTypeCell}"/>
                                <GridViewColumn Header="삭제 시간"   Width="210"
                                                HeaderContainerStyle="{StaticResource ColHeader}"
                                                CellTemplate="{StaticResource DeletedAtCell}"/>
                                <GridViewColumn Header="만료 기한"    Width="175"
                                                HeaderContainerStyle="{StaticResource ColHeaderLast}"
                                                CellTemplate="{StaticResource RemainCell}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                </Grid>
            </Grid>
        </Border>

        <!-- ══ 우측 사이드 패널 ══ -->
        <Border Grid.Column="1" Background="{StaticResource Panel}">
            <DockPanel Margin="14,32,14,14">

                <!--   하단 버튼 먼저 Dock → 절대 짤리지 않음 -->
                <StackPanel DockPanel.Dock="Bottom">
                    <Border Height="1" Background="#244A66" Margin="0,0,0,16"/>
                    <Button Style="{StaticResource ExitBtn}"
                            Width="120"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Stretch"
                            Command="{Binding NavigateBackCommand}">
                        <Viewbox Width="36" Height="36" Stretch="Uniform">
                            <Path Fill="White"
                                  Data="M30.27,74.4L4.34,48.47c-1.79-1.79-1.02-4.45.57-6.03l25.56-25.43c1.66-1.66,4.54-.94,5.8.51,1.62,1.87,1.33,4.35-.38,6.06l-17.97,17.95,49.14.02c16.67,0,29.7,13.76,29.63,30.41l-.04,8.1c-.01,2.36-2.19,3.98-4.37,3.89s-4.07-1.93-4.07-4.29l-.02-8.95c-.02-11.34-9.52-20.64-20.94-20.64l-49.35-.03,18.33,18.37c1.63,1.63,1.43,4.24-.1,5.81-1.41,1.45-4.15,1.91-5.85.2Z"/>
                        </Viewbox>
                    </Button>
                </StackPanel>

                <!-- 상단: 로고 + 섹션 타이틀 + 복구 버튼 -->
                <StackPanel DockPanel.Dock="Top">

                    <!--   LSS 로고 (User.xaml / Patient.xaml 동일 구조) -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,36">
                        <TextBlock Text="LSS" FontSize="28" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"/>
                        <Border Height="2" Width="44" Background="#2A6496"
                                Margin="0,8,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- 복구 버튼 -->
                    <Button Style="{StaticResource RecoverBtn}"
                            Content="복구"
                            Command="{Binding RecoverCommand}"
                            Margin="0,0,0,0"/>

                    <!-- 즉시 삭제 버튼 -->
                    <Button Style="{StaticResource RecoverBtn}"
                            Background="Red"
                            Content="즉시 삭제"
                            Command="{Binding ForceDeleteCommand}"
                            Margin="0,50,0,0"/>

                </StackPanel>

            </DockPanel>
        </Border>

        <!-- 전원 메뉴 버튼 오버레이 (우하단 고정) -->
        <Grid Grid.ColumnSpan="2" Panel.ZIndex="99"
              HorizontalAlignment="Right" VerticalAlignment="Bottom"
              Margin="0,0,20,15" x:Name="MenuButtonArea">
            <Button x:Name="MenuToggleBtn"
                    Style="{StaticResource MenuToggleStyle}"
                    Command="{Binding ToggleMenuCommand}">
                <TextBlock Text="⏻" FontSize="35"/>
            </Button>
            <Popup x:Name="MenuPopup"
                   IsOpen="{Binding IsMenuOpen, Mode=TwoWay}"
                   PlacementTarget="{Binding ElementName=MenuToggleBtn}"
                   Placement="Top"
                   StaysOpen="False"
                   AllowsTransparency="True"
                   PopupAnimation="Fade">
                <Border Background="#1F2937" CornerRadius="10"
                        Padding="6" Margin="0,0,0,6">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.4"
                                          BlurRadius="12" ShadowDepth="4" Direction="270"/>
                    </Border.Effect>
                    <StackPanel MinWidth="200">
                        <!-- Lock -->
                        <Button Style="{StaticResource PopupMenuItemBtn}"
                                Command="{Binding LockCommand}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="22" Width="36" TextAlignment="Center"
                                           VerticalAlignment="Center" Margin="0,0,14,0"/>
                                <TextBlock Text="Lock" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <!-- Log Out -->
                        <Button Style="{StaticResource PopupMenuItemBtn}"
                                Command="{Binding LogoutCommand}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#xF3B1;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="22" Width="36" TextAlignment="Center"
                                           VerticalAlignment="Center" Margin="0,0,14,0"/>
                                <TextBlock Text="Log Out" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <!-- Exit -->
                        <Button Style="{StaticResource PopupMenuItemBtn}"
                                Command="{Binding ExitCommand}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#xE7E8;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="22" Width="36" TextAlignment="Center"
                                           VerticalAlignment="Center" Margin="0,0,14,0"/>
                                <TextBlock Text="Exit" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>

    </Grid>
</UserControl>

<UserControl x:Class="LSS_prototype.VideoComment_Page.VideoComment"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Height="1080" Width="1920"
        Background="#173753"
        d:DesignWidth="1920" d:DesignHeight="1080">

    <UserControl.Resources>
        <SolidColorBrush x:Key="Panel"      Color="#1C2B3A"/>
        <SolidColorBrush x:Key="Card"       Color="#243447"/>
        <SolidColorBrush x:Key="CardBorder" Color="#2E4460"/>
        <SolidColorBrush x:Key="ValueBg"    Color="#1A2D3E"/>
        <SolidColorBrush x:Key="BtnDark"    Color="#2A3F55"/>
        <SolidColorBrush x:Key="Inactive"   Color="#94A3B8"/>
        <SolidColorBrush x:Key="Accent"     Color="#3B82F6"/>

        <Style x:Key="BaseBtn" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background" Value="{StaticResource BtnDark}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize"   Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="AccentBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize"   Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="PlayBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="SeekBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background" Value="{StaticResource BtnDark}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background" Value="#7F1D1D"/>
            <Setter Property="Foreground" Value="#FCA5A5"/>
            <Setter Property="FontSize"   Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="ExitBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background"      Value="#111827"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontSize"        Value="20"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="72"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>

        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Background"      Value="{StaticResource Card}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderBrush"     Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="17"/>
            <Setter Property="Height"          Value="52"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0"
                                    Content="{TemplateBinding SelectionBoxItem}"
                                    Margin="14,0,0,0" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="▾"
                                           Foreground="{StaticResource Inactive}"
                                           FontSize="14" VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                                <Popup x:Name="PART_Popup"
                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                       Placement="Bottom" AllowsTransparency="True">
                                    <Border Background="{StaticResource Card}"
                                            BorderBrush="{StaticResource CardBorder}"
                                            BorderThickness="1" CornerRadius="10"
                                            MinWidth="{TemplateBinding ActualWidth}">
                                        <ScrollViewer MaxHeight="220">
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground"  Value="White"/>
                        <Setter Property="Background"  Value="{StaticResource Card}"/>
                        <Setter Property="Padding"     Value="14,10"/>
                        <Setter Property="FontSize"    Value="16"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="{StaticResource BtnDark}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PmBtn" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Background"      Value="#2A3F55"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontSize"        Value="22"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse Fill="{TemplateBinding Background}"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3B5570"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#3B82F6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SeekSlider" TargetType="Slider">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Height="44" Background="Transparent">
                                <Grid VerticalAlignment="Center">
                                    <Border Height="6" CornerRadius="3"
                                            Background="{StaticResource BtnDark}" Margin="22,0"/>
                                    <Track x:Name="PART_Track" Margin="0">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Command="Slider.DecreaseLarge" Focusable="False">
                                                <RepeatButton.Template>
                                                    <ControlTemplate TargetType="RepeatButton">
                                                        <Border Height="6" CornerRadius="3,0,0,3"
                                                                Background="{StaticResource Accent}"
                                                                VerticalAlignment="Center"/>
                                                    </ControlTemplate>
                                                </RepeatButton.Template>
                                            </RepeatButton>
                                        </Track.DecreaseRepeatButton>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Command="Slider.IncreaseLarge" Focusable="False">
                                                <RepeatButton.Template>
                                                    <ControlTemplate TargetType="RepeatButton">
                                                        <Border Background="Transparent"/>
                                                    </ControlTemplate>
                                                </RepeatButton.Template>
                                            </RepeatButton>
                                        </Track.IncreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb>
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Grid Width="36" Height="36">
                                                            <Ellipse Fill="#40000000" Margin="-2"/>
                                                            <Ellipse Fill="White"/>
                                                            <Ellipse Width="12" Height="12"
                                                                     Fill="{StaticResource Accent}"
                                                                     HorizontalAlignment="Center"
                                                                     VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid Background="{StaticResource Panel}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="440"/>
        </Grid.ColumnDefinitions>

        <!-- ══ 좌측: 영상 재생 영역 ══ -->
        <Border Grid.Column="0" Background="Black"
                Margin="10,10,5,10" CornerRadius="8" ClipToBounds="True">
            <Grid>
                <MediaElement x:Name="VideoPlayer"
                              LoadedBehavior="Manual"
                              UnloadedBehavior="Stop"
                              Stretch="Uniform"
                              ScrubbingEnabled="True"
                              MediaOpened="VideoPlayer_MediaOpened"
                              MediaEnded="VideoPlayer_MediaEnded"/>

                <!-- 환자 정보 좌상단 -->
                <StackPanel Margin="16,14" VerticalAlignment="Top" HorizontalAlignment="Left">
                    <TextBlock Text="{Binding PatientName}"
                               Foreground="White" FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text="{Binding PatientInfo}"
                               Foreground="#BBCCE0" FontSize="15"/>
                </StackPanel>

                <!-- VideoType + PageIndicator 우상단 -->
                <StackPanel Margin="16,14" VerticalAlignment="Top" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding VideoType, Mode=OneWay}"
                               Foreground="White" FontSize="18" FontWeight="Bold"
                               HorizontalAlignment="Right"/>
                    <TextBlock Text="{Binding PageIndicator}"
                               Foreground="White" FontSize="18" FontWeight="Bold"
                               HorizontalAlignment="Right"/>
                </StackPanel>

                <!-- ── 하단 컨트롤 오버레이 ── -->
                <Border VerticalAlignment="Bottom"
                        Background="#CC1C2B3A"
                        CornerRadius="0,0,8,8"
                        Padding="16,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="70"/>
                        </Grid.RowDefinitions>

                        <!-- Seek 슬라이더 + 시간 -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" x:Name="TxtCurrentTime" Text="00:00"
                                       Foreground="White" FontSize="15" FontWeight="Bold"
                                       FontFamily="Courier New" VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>
                            <Slider Grid.Column="1" x:Name="SliderSeek"
                                    Style="{StaticResource SeekSlider}"
                                    Minimum="0" Maximum="100" Value="0"
                                    IsMoveToPointEnabled="True"
                                    PreviewMouseDown="SliderSeek_PreviewMouseDown"
                                    PreviewMouseUp="SliderSeek_PreviewMouseUp"
                                    ValueChanged="SliderSeek_ValueChanged"/>
                            <TextBlock Grid.Column="2" x:Name="TxtTotalTime" Text="00:00"
                                       Foreground="{StaticResource Inactive}" FontSize="15"
                                       FontFamily="Courier New" VerticalAlignment="Center"
                                       Margin="10,0,0,0"/>
                        </Grid>

                        <!-- 컨트롤 버튼 한 줄 -->
                        <Grid Grid.Row="2">
                            <!-- 속도 표시 레이블 -->
                            <Border HorizontalAlignment="Left" VerticalAlignment="Center"
            Background="{StaticResource ValueBg}"
            CornerRadius="8" Padding="14,0" Height="44">
                                <TextBlock Text="{Binding SpeedLabel}"
                   Foreground="{Binding SpeedLabelColor}"
                   FontSize="16" FontWeight="Bold"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

                                <!-- 느리게 -->
                                <Button Style="{StaticResource SeekBtn}"
                Width="70" Height="70" Margin="0,0,8,0"
                Command="{Binding SlowerCommand}">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="🐢" FontSize="22" HorizontalAlignment="Center"/>
                                        <TextBlock Text="느리게" FontSize="10"
                           Foreground="{StaticResource Inactive}"
                           HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Button>

                                <!-- -1초 -->
                                <Button Style="{StaticResource SeekBtn}"
                Width="70" Height="70" Margin="0,0,8,0"
                Command="{Binding SeekBackCommand}">
                                    <Viewbox Width="40" Height="40" Stretch="Uniform">
                                        <Canvas Width="100" Height="100">
                                            <Path Stroke="White" StrokeThickness="8"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Fill="Transparent"
                          Data="M36.89,17.22c4.11-1.42,8.52-2.2,13.11-2.2,22.09,0,40,17.91,40,40s-17.91,40-40,40S10,77.12,10,55.02c0-7.03,1.81-13.63,5-19.37"/>
                                            <Path Fill="White"
                          Data="M25.19,22.96l19.31,3.67c1.34.25,2.44-1.05,1.97-2.33l-7.09-19.06c-.48-1.28-2.17-1.55-3.01-.48l-12.22,15.4c-.82,1.03-.25,2.57,1.05,2.81Z"/>
                                            <TextBlock Canvas.Left="28" Canvas.Top="38"
                               Text="1s" Foreground="White"
                               FontFamily="Arial" FontSize="26" FontWeight="Bold"/>
                                        </Canvas>
                                    </Viewbox>
                                </Button>

                                <!-- 재생/일시정지 -->
                                <Button Style="{StaticResource PlayBtn}"
                Width="100" Height="70"
                Command="{Binding PlayPauseCommand}">
                                    <Grid>
                                        <Viewbox Width="72" Height="72" Stretch="Uniform"
                         Visibility="{Binding PlayIconVisibility}">
                                            <Canvas Width="100" Height="100">
                                                <Path Fill="White"
                              Data="M66.53,49.1l-23.98-14.23c-.7-.41-1.57.09-1.57.9v28.46c0,.81.88,1.31,1.57.9l23.98-14.23c.68-.4.68-1.39,0-1.79Z"/>
                                            </Canvas>
                                        </Viewbox>
                                        <Viewbox Width="72" Height="72" Stretch="Uniform"
                         Visibility="{Binding PauseIconVisibility}">
                                            <Canvas Width="100" Height="100">
                                                <Path Fill="White"
                              Data="M40.66,35.69H44.27A1.52,1.52,0,0,1,45.79,37.21V62.78A1.52,1.52,0,0,1,44.27,64.3H40.66A1.52,1.52,0,0,1,39.14,62.78V37.21A1.52,1.52,0,0,1,40.66,35.69Z"/>
                                                <Path Fill="White"
                              Data="M55.73,35.69H59.34A1.52,1.52,0,0,1,60.86,37.21V62.78A1.52,1.52,0,0,1,59.34,64.3H55.73A1.52,1.52,0,0,1,54.21,62.78V37.21A1.52,1.52,0,0,1,55.73,35.69Z"/>
                                            </Canvas>
                                        </Viewbox>
                                    </Grid>
                                </Button>

                                <!-- +1초 -->
                                <Button Style="{StaticResource SeekBtn}"
                Width="70" Height="70" Margin="8,0,8,0"
                Command="{Binding SeekForwardCommand}">
                                    <Viewbox Width="40" Height="40" Stretch="Uniform">
                                        <Canvas Width="100" Height="100">
                                            <Path Stroke="White" StrokeThickness="8"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Fill="Transparent"
                          Data="M63.11,17.67c-4.11-1.42-8.52-2.2-13.11-2.2-22.09,0-40,17.91-40,40,0,22.09,17.91,40,40,40s40-17.91,40-40c0-7.03-1.81-13.63-5-19.37"/>
                                            <Path Fill="White"
                          Data="M74.81,23.4l-19.31,3.67c-1.34.25-2.44-1.05-1.97-2.33l7.09-19.06c.48-1.28,2.17-1.55,3.01-.48l12.22,15.4c.82,1.03.25,2.57-1.05,2.81Z"/>
                                            <TextBlock Canvas.Left="28" Canvas.Top="38"
                               Text="1s" Foreground="White"
                               FontFamily="Arial" FontSize="26" FontWeight="Bold"/>
                                        </Canvas>
                                    </Viewbox>
                                </Button>

                                <!-- 빠르게 -->
                                <Button Style="{StaticResource SeekBtn}"
                Width="70" Height="70" Margin="0,0,0,0"
                Command="{Binding FasterCommand}">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="🐇" FontSize="22" HorizontalAlignment="Center"/>
                                        <TextBlock Text="빠르게" FontSize="10"
                           Foreground="{StaticResource Inactive}"
                           HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Button>

                            </StackPanel>

                            <!-- 계기판 (속도 팝업) — 맨 우측 -->
                            <Grid x:Name="SpeedBtnArea"
                                  HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button Style="{StaticResource SeekBtn}"
                    Width="70" Height="70"
                    Command="{Binding ToggleSpeedPopupCommand}">
                                    <Viewbox Width="36" Height="36" Stretch="Uniform">
                                        <Canvas Width="100" Height="100">
                                            <Path Stroke="White" StrokeThickness="8"
                          StrokeStartLineCap="Round" StrokeLineJoin="Round"
                          StrokeEndLineCap="Round"
                          Fill="Transparent"
                          Data="M16.48,82.63c-4.86-6.77-7.73-15.07-7.73-24.04,0-22.78,18.47-41.25,41.25-41.25,5.76,0,11.25,1.18,16.23,3.31"/>
                                            <Path Stroke="White" StrokeThickness="8"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Fill="Transparent"
                          Data="M87.38,41.12c2.48,5.3,3.87,11.22,3.87,17.47,0,8.98-2.87,17.29-7.74,24.06"/>
                                            <Path Fill="White"
                          Data="M81.8,24.95l-37.49,29.81c-3.27,2.6-3.46,7.51-.39,10.35l1.32,1.22c3.07,2.84,7.95,2.28,10.29-1.19l26.83-39.67c.25-.37-.22-.8-.56-.52Z"/>
                                        </Canvas>
                                    </Viewbox>
                                </Button>

                                <!-- 속도 팝업 -->
                                <Popup x:Name="SpeedPopup"
                   IsOpen="{Binding IsSpeedPopupOpen, Mode=TwoWay}"
                   PlacementTarget="{Binding ElementName=SpeedBtnArea}"
                   Placement="Top"
                   StaysOpen="False"
                   AllowsTransparency="True"
                   PopupAnimation="Fade">
                                    <Border Background="#0F1E2D" CornerRadius="16"
                    Padding="24" Margin="0,0,0,8" Width="420">
                                        <Border.Effect>
                                            <DropShadowEffect Color="Black" Opacity="0.5"
                                      BlurRadius="16" ShadowDepth="4" Direction="270"/>
                                        </Border.Effect>
                                        <StackPanel>

                                            <!-- 현재 속도 표시 -->
                                            <TextBlock Text="{Binding SpeedLabel}"
                               FontSize="36" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center"
                               Margin="0,0,0,16"/>

                                            <!-- 슬라이더 영역 -->
                                            <Grid Margin="0,0,0,16">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="48"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="48"/>
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0" Content="−"
                                Style="{StaticResource PmBtn}"
                                Width="48" Height="48"
                                Command="{Binding SpeedDownCommand}"/>
                                                <Slider Grid.Column="1"
                                Minimum="0.25" Maximum="4"
                                TickFrequency="0.25" IsSnapToTickEnabled="True"
                                Value="{Binding CurrentSpeedRatio, Mode=TwoWay}"
                                VerticalAlignment="Center"
                                Margin="12,0"/>
                                                <Button Grid.Column="2" Content="+"
                                Style="{StaticResource PmBtn}"
                                Width="48" Height="48"
                                Command="{Binding SpeedUpCommand}"/>
                                            </Grid>

                                            <!-- 프리셋 버튼 -->
                                            <StackPanel Orientation="Horizontal"
                                                        HorizontalAlignment="Center">
                                                <Button Content="x0.25" Style="{StaticResource DarkBtn}"
                                FontSize="13" Width="68" Height="48" Margin="0,0,6,0"
                                Command="{Binding SetSpeedCommand}" CommandParameter="0.25"/>
                                                <Button Content="x0.5"  Style="{StaticResource DarkBtn}"
                                FontSize="13" Width="68" Height="48" Margin="0,0,6,0"
                                Command="{Binding SetSpeedCommand}" CommandParameter="0.5"/>
                                                <Button Content="x1"    Style="{StaticResource DarkBtn}"
                                FontSize="13" Width="68" Height="48" Margin="0,0,6,0"
                                Command="{Binding SetSpeedCommand}" CommandParameter="1"/>
                                                <Button Content="x2"    Style="{StaticResource DarkBtn}"
                                FontSize="13" Width="68" Height="48" Margin="0,0,6,0"
                                Command="{Binding SetSpeedCommand}" CommandParameter="2"/>
                                                <Button Content="x4"    Style="{StaticResource DarkBtn}"
                                FontSize="13" Width="68" Height="48"
                                Command="{Binding SetSpeedCommand}" CommandParameter="4"/>
                                            </StackPanel>

                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </Grid>

                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ══ 우측 패널 ══ -->
        <Grid Grid.Column="1" Margin="5,10,10,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="90"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource Card}" CornerRadius="12">
                <Grid Margin="16,18,16,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- R0:  Position 라벨 -->
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="52"/>
                        <!-- R2:  Position 콤보 -->
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <!-- R4:  Anatomical 라벨 -->
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="52"/>
                        <!-- R6:  Anatomical 콤보 -->
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <!-- R8:  Comment 라벨 -->
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="430"/>
                        <!-- R10: Comment 입력 (고정) -->
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="66"/>
                        <!-- R12: VIDEO DELETE -->
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="66"/>
                        <!-- R14: RESET -->
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="66"/>
                        <!-- R16: SAVE -->
                    </Grid.RowDefinitions>

                    <!-- Position -->
                    <TextBlock Grid.Row="0" Text="Position"
                               Foreground="White" FontSize="18" FontWeight="Bold"/>
                    <ComboBox Grid.Row="2" Style="{StaticResource DarkCombo}"
                              SelectedItem="{Binding SelectedPosition}">
                        <ComboBoxItem>Left</ComboBoxItem>
                        <ComboBoxItem>Right</ComboBoxItem>
                        <ComboBoxItem>Top</ComboBoxItem>
                        <ComboBoxItem>Bottom</ComboBoxItem>
                    </ComboBox>

                    <!-- Anatomical -->
                    <TextBlock Grid.Row="4" Text="Anatomical Directional"
                               Foreground="White" FontSize="18" FontWeight="Bold"/>
                    <ComboBox Grid.Row="6" Style="{StaticResource DarkCombo}"
                              SelectedItem="{Binding SelectedAnatomical}">
                        <ComboBoxItem>Anterior</ComboBoxItem>
                        <ComboBoxItem>Posterior</ComboBoxItem>
                        <ComboBoxItem>Lateral</ComboBoxItem>
                        <ComboBoxItem>Medial</ComboBoxItem>
                    </ComboBox>

                    <!-- Comment -->
                    <TextBlock Grid.Row="8" Text="Comment"
                               Foreground="White" FontSize="18" FontWeight="Bold"/>
                    <Border Grid.Row="10" Background="{StaticResource ValueBg}"
                            BorderBrush="{StaticResource CardBorder}"
                            BorderThickness="1" CornerRadius="10">
                        <TextBox Background="Transparent" BorderThickness="0"
                                 Foreground="White" FontSize="15"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Padding="12,10" CaretBrush="White"
                                 Text="{Binding CommentText, UpdateSourceTrigger=PropertyChanged}"/>
                    </Border>

                    <!-- VIDEO DELETE -->
                    <Button Grid.Row="12"
                            Content="VIDEO DELETE"
                            Style="{StaticResource DangerBtn}"
                            Command="{Binding VideoDeleteCommand}"/>

                    <!-- RESET -->
                    <Button Grid.Row="14"
                            Content="RESET"
                            Style="{StaticResource DarkBtn}"
                            Command="{Binding ResetCommand}"/>

                    <!-- SAVE -->
                    <Button Grid.Row="16"
                            Content="SAVE"
                            Style="{StaticResource AccentBtn}"
                            Command="{Binding SaveCommand}"/>

                </Grid>
            </Border>

            <!-- BACK -->
            <Grid Grid.Row="2" VerticalAlignment="Center">
                <Button Style="{StaticResource ExitBtn}"
            Width="120"
            HorizontalAlignment="Left"
            VerticalAlignment="Stretch"
            Margin="0,0,0,0"
            Command="{Binding NavigateBackCommand}">
                    <Viewbox Width="36" Height="36" Stretch="Uniform">
                        <Path Fill="White"
                  Data="M30.27,74.4L4.34,48.47c-1.79-1.79-1.02-4.45.57-6.03l25.56-25.43c1.66-1.66,4.54-.94,5.8.51,1.62,1.87,1.33,4.35-.38,6.06l-17.97,17.95,49.14.02c16.67,0,29.7,13.76,29.63,30.41l-.04,8.1c-.01,2.36-2.19,3.98-4.37,3.89s-4.07-1.93-4.07-4.29l-.02-8.95c-.02-11.34-9.52-20.64-20.94-20.64l-49.35-.03,18.33,18.37c1.63,1.63,1.43,4.24-.1,5.81-1.41,1.45-4.15,1.91-5.85.2Z"/>
                    </Viewbox>
                </Button>
            </Grid>
        </Grid>

        <!-- 전원 메뉴 버튼 오버레이 (우하단 고정) -->
        <Grid Grid.ColumnSpan="2" Panel.ZIndex="99"
              HorizontalAlignment="Right" VerticalAlignment="Bottom"
              Margin="0,0,20,17" x:Name="MenuButtonArea">
            <Button x:Name="MenuToggleBtn"
                    Style="{StaticResource MenuToggleStyle}"
                    Command="{Binding ToggleMenuCommand}">
                <TextBlock Text="⏻" FontSize="35"/>
            </Button>
            <Popup x:Name="MenuPopup"
                   IsOpen="{Binding IsMenuOpen, Mode=TwoWay}"
                   PlacementTarget="{Binding ElementName=MenuToggleBtn}"
                   Placement="Top"
                   StaysOpen="False"
                   AllowsTransparency="True"
                   PopupAnimation="Fade">
                <Border Background="#1F2937" CornerRadius="10"
                        Padding="6" Margin="0,0,0,6">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.4"
                                          BlurRadius="12" ShadowDepth="4" Direction="270"/>
                    </Border.Effect>
                    <StackPanel MinWidth="200">
                        <!-- Lock -->
                        <Button Style="{StaticResource PopupMenuItemBtn}"
                                Command="{Binding LockCommand}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="22" Width="36" TextAlignment="Center"
                                           VerticalAlignment="Center" Margin="0,0,14,0"/>
                                <TextBlock Text="Lock" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <!-- Log Out -->
                        <Button Style="{StaticResource PopupMenuItemBtn}"
                                Command="{Binding LogoutCommand}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#xF3B1;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="22" Width="36" TextAlignment="Center"
                                           VerticalAlignment="Center" Margin="0,0,14,0"/>
                                <TextBlock Text="Log Out" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <!-- Exit -->
                        <Button Style="{StaticResource PopupMenuItemBtn}"
                                Command="{Binding ExitCommand}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#xE7E8;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="22" Width="36" TextAlignment="Center"
                                           VerticalAlignment="Center" Margin="0,0,14,0"/>
                                <TextBlock Text="Exit" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>
    </Grid>
</UserControl>
